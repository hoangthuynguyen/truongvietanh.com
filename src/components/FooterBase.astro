---
// src/components/FooterBase.astro
const logoUrl = "/logo-vietanh.png";
---

<footer class="custom-footer">
  <div class="cf-container">
    <div class="footer-grid">
      <!-- Column 1 -->
      <div class="footer-col brand-col">
        <img src={logoUrl} alt="Trường Liên Cấp Việt Anh" class="footer-logo" />
        <p class="footer-desc">Đào tạo học sinh Giỏi Chuyên Môn, Sáng Nhân Cách, chuẩn bị hành trang vững chắc cho tương lai với 16 Kỹ năng thế kỷ 21.</p>
        <div class="social-links">
          <a href="#" aria-label="Facebook">Fb</a>
          <a href="#" aria-label="YouTube">Yt</a>
          <a href="#" aria-label="TikTok">Tt</a>
        </div>
      </div>
      
      <!-- Column 2 -->
      <div class="footer-col">
        <h4 class="footer-heading">Chương Trình Đào Tạo</h4>
        <ul class="footer-links">
          <li><a href="/mam-non">Mầm Non (Dưới 6 tuổi)</a></li>
          <li><a href="/tieu-hoc">Tiểu Học (6 - 9 tuổi)</a></li>
          <li><a href="/trung-hoc-co-so">THCS (10 - 13 tuổi)</a></li>
          <li><a href="/trung-hoc-pho-thong">THPT (14 - 16 tuổi)</a></li>
          <li><a href="/ngoai-khoa">Ngoại Khóa (6 - 16 tuổi)</a></li>
        </ul>
      </div>

      <!-- Column 3 -->
      <div class="footer-col">
        <h4 class="footer-heading">Liên Kết Nhanh</h4>
        <ul class="footer-links">
          <li><a href="/gioi-thieu">Về Chúng Tôi</a></li>
          <li><a href="/tuyen-sinh">Đăng Ký Tuyển Sinh</a></li>
          <li><a href="/hoc-phi">Chính Sách Học Phí</a></li>
          <li><a href="/thanh-tich">Thành Tích Học Sinh</a></li>
          <li><a href="/phu-huynh">Góc Phụ Huynh</a></li>
          <li><a href="/lien-he">Liên Hệ</a></li>
        </ul>
      </div>
    </div>
    
    <div class="footer-campuses">
      <h4 class="footer-heading text-center" style="margin-bottom: 1.5rem;">Hệ Thống Cơ Sở</h4>
      <div class="campus-grid">
        <div class="campus-card">
          <h5>Cơ sở Gò Vấp</h5>
          <p>160/72 Phan Huy Ích, P.12, Q.Gò Vấp, TP.HCM</p>
          <a href="tel:0916961409" class="campus-hotline">Hotline: 0916 961 409</a>
        </div>
        <div class="campus-card">
          <h5>Cơ sở Phú Nhuận</h5>
          <p>269A Nguyễn Trọng Tuyển, P.10, Q.Phú Nhuận, TP.HCM</p>
          <a href="tel:0916961409" class="campus-hotline">Hotline: 0916 961 409</a>
        </div>
        <div class="campus-card">
          <h5>Cơ sở Bình Tân</h5>
          <p>951/7 Tỉnh lộ 10, P.Tân Tạo, Q.Bình Tân, TP.HCM</p>
          <a href="tel:0916961409" class="campus-hotline">Hotline: 0916 961 409</a>
        </div>
        <div class="campus-card">
          <h5>Mầm Non Gò Vấp</h5>
          <p>573 Lê Đức Thọ, P.16, Q.Gò Vấp, TP.HCM</p>
          <a href="tel:0916961409" class="campus-hotline">Hotline: 0916 961 409</a>
        </div>
        <div class="campus-card">
          <h5>Trường Mầm Non Long Hậu</h5>
          <p>Khu dân cư Long Hậu, Tỉnh Long An</p>
          <a href="tel:0916961409" class="campus-hotline">Hotline: 0916 961 409</a>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <div class="bottom-flex">
        <p>&copy; {new Date().getFullYear()} Trường Liên Cấp Việt Anh. All rights reserved.</p>
        <div class="legal-links">
          <a href="/privacy">Bảo mật</a>
          <a href="/terms">Điều khoản</a>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  /* UTILS for footer */
  .cf-container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .text-center { text-align: center; }

  /* FOOTER */
  .custom-footer { background: var(--cf-blue, #1a193c); color: #f8fafc; padding: 5rem 0 2rem; font-family: 'Inter', sans-serif; font-size: 0.95rem; line-height: 1.6; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1.5fr 1.5fr; gap: 4rem; margin-bottom: 4rem; }
  .brand-col { max-width: 400px; }
  .footer-logo { height: 75px; object-fit: contain; margin-bottom: 1.5rem; filter: brightness(0) invert(1); opacity: 0.9; }
  .footer-desc { color: #cbd5e1; margin-bottom: 1.5rem; font-weight: 300; }
  .social-links { display: flex; gap: 1rem; }
  .social-links a { display: inline-flex; align-items: center; justify-content: center; width: 40px; height: 40px; border-radius: 50%; background: rgba(255,255,255,0.1); color: #fff; text-decoration: none; font-weight: bold; transition: all 0.2s; }
  .social-links a:hover { background: var(--pri-yellow, #fde047); color: #000; }
  
  .footer-heading { font-size: 1.15rem; font-weight: 600; margin-bottom: 1.5rem; color: #fff; position: relative; padding-bottom: 0.75rem; }
  .footer-heading::after { content: ''; position: absolute; left: 0; bottom: 0; width: 40px; height: 2px; background: var(--pri-yellow, #fde047); }
  .text-center.footer-heading::after { left: 50%; transform: translateX(-50%); width: 60px; }
  
  .footer-links { list-style: none; padding: 0; margin: 0; }
  .footer-links li { margin-bottom: 0.85rem; }
  .footer-links a { color: #cbd5e1; text-decoration: none; transition: all 0.2s; display: inline-block; }
  .footer-links a:hover { color: var(--pri-yellow, #fde047); transform: translateX(5px); }

  .footer-campuses { background: rgba(255,255,255,0.03); padding: 3rem 2rem; border-radius: 12px; margin-bottom: 3rem; border: 1px solid rgba(255,255,255,0.05); }
  .campus-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; }
  .campus-card h5 { color: #fff; margin: 0 0 0.5rem 0; font-size: 1rem; font-weight: 600; }
  .campus-card p { color: #94a3b8; font-size: 0.85rem; margin: 0 0 0.75rem 0; line-height: 1.5; }
  .campus-hotline { color: var(--pri-yellow, #fde047); font-weight: 600; text-decoration: none; font-size: 0.9rem; display: inline-block; padding: 0.35rem 0.75rem; background: rgba(253, 224, 71, 0.1); border-radius: 4px; }
  .campus-hotline:hover { background: rgba(253, 224, 71, 0.2); }

  .footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 2rem; color: #64748b; font-size: 0.85rem; }
  .bottom-flex { display: flex; justify-content: space-between; align-items: center; }
  .legal-links { display: flex; gap: 1.5rem; }
  .legal-links a { color: #64748b; text-decoration: none; transition: color 0.2s; }
  .legal-links a:hover { color: #fff; }

  /* RESPONSIVE FOOTER */
  @media (max-width: 900px) {
    .footer-grid { grid-template-columns: 1fr; gap: 3rem; }
    .brand-col { max-width: 100%; }
    .footer-heading::after { content: none; /* simple line layout on mobile */ }
  }
  @media (max-width: 600px) {
    .bottom-flex { flex-direction: column; gap: 1rem; text-align: center; }
  }
</style>
