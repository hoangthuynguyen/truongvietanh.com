---
// src/components/FooterBase.astro — matching reference screenshot
const logoUrl = "/logo-vietanh.png";
---

<footer class="site-footer">
  <!-- TOP BAR: Logo + Campus addresses -->
  <div class="footer-top-bar">
    <div class="footer-container">
      <div class="campus-bar">
        <div class="campus-logo-col">
          <img src={logoUrl} alt="Trường Việt Anh" class="footer-logo-img" />
        </div>
        <div class="campus-address-col">
          <strong>Cơ sở Việt Anh Gò Vấp:</strong> 160/72 Phan Huy Ích, phường An Hội Tây, Thành phố Hồ Chí Minh
          <br /><span class="hotline-text">Hotline: <a href="tel:0916961409" class="hotline-link">091 6961 409</a></span>
        </div>
        <div class="campus-address-col">
          <strong>Cơ sở Việt Anh Phú Nhuận:</strong> 269A Nguyễn Trọng Tuyển, phường Phú Nhuận, Thành phố Hồ Chí Minh
          <br /><span class="hotline-text">Hotline: <a href="tel:0916961409" class="hotline-link">0916 961 409</a></span>
        </div>
        <div class="campus-address-col">
          <strong>Cơ sở Việt Anh Bình Tân:</strong> 951/7 Tỉnh lộ 10, phường Bình Tân, Thành phố Hồ Chí Minh
          <br /><span class="hotline-text">Hotline: <a href="tel:0916961409" class="hotline-link">0916 961 409</a></span>
        </div>
      </div>
    </div>
  </div>

  <!-- MAIN FOOTER: 5 columns -->
  <div class="footer-main">
    <div class="footer-container">
      <div class="footer-5col">
        <!-- Col 1: Giới thiệu -->
        <div class="footer-col footer-col--intro">
          <h4 class="footer-heading">Giới thiệu</h4>
          <p class="footer-intro-text">Hầu hết học sinh Việt Nam vừa khao khát vừa sợ hãi cơ hội du học. Vì vậy, trường Việt Anh được thiết kế để chuẩn bị tốt tiếng Anh và các phẩm chất, năng lực cần có. Nhờ đó, học sinh tự tin du học, nhiều em đã nhận được những học bổng giá trị từ nhiều đại học hàng đầu thế giới.</p>
          <div class="social-icons">
            <a href="https://www.facebook.com/truongvietanh" target="_blank" rel="noreferrer" aria-label="Facebook">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
            </a>
            <a href="https://www.youtube.com/@truongvietanh" target="_blank" rel="noreferrer" aria-label="YouTube">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M22.54 6.42a2.78 2.78 0 00-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 00-1.94 2A29 29 0 001 11.75a29 29 0 00.46 5.33A2.78 2.78 0 003.4 19.1c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 001.94-2 29 29 0 00.46-5.25 29 29 0 00-.46-5.43zM9.75 15.02V8.48l5.75 3.27-5.75 3.27z"/></svg>
            </a>
            <a href="https://www.instagram.com/truongvietanh" target="_blank" rel="noreferrer" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
            </a>
          </div>
        </div>

        <!-- Col 2: Phụ huynh -->
        <div class="footer-col">
          <h4 class="footer-heading">Phụ huynh</h4>
          <ul class="footer-links">
            <li><a href="/phu-huynh">Phụ huynh - Học sinh</a></li>
            <li><a href="#">Thời khoá biểu</a></li>
            <li><a href="#">Thực đơn</a></li>
            <li><a href="#">Công Khai</a></li>
          </ul>
        </div>

        <!-- Col 3: Thông tin -->
        <div class="footer-col">
          <h4 class="footer-heading">Thông tin</h4>
          <ul class="footer-links">
            <li><a href="#">Blog</a></li>
            <li><a href="#">Câu hỏi thường gặp</a></li>
            <li><a href="#">Hình Ảnh</a></li>
          </ul>
        </div>

        <!-- Col 4: Chương trình đào tạo -->
        <div class="footer-col">
          <h4 class="footer-heading">Chương trình đào tạo</h4>
          <ul class="footer-links">
            <li><a href="/mam-non">Chương trình Mầm Non</a></li>
            <li><a href="/tieu-hoc">Chương trình Tiểu Học</a></li>
            <li><a href="/trung-hoc-co-so">Chương trình THCS</a></li>
            <li><a href="/trung-hoc-pho-thong">Chương trình THPT</a></li>
          </ul>
        </div>

        <!-- Col 5: Hệ thống giáo dục Major Education -->
        <div class="footer-col">
          <h4 class="footer-heading">Hệ thống giáo dục Major Education</h4>
          <ul class="footer-links">
            <li><a href="/mam-non">Chương trình Mầm Non</a></li>
            <li><a href="/tieu-hoc">Chương trình Tiểu Học</a></li>
            <li><a href="/trung-hoc-co-so">Chương trình THCS</a></li>
            <li><a href="/trung-hoc-pho-thong">Chương trình THPT</a></li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- COPYRIGHT -->
  <div class="footer-copyright">
    <div class="footer-container">
      <p>&copy; {new Date().getFullYear()} truongvietanh.com</p>
    </div>
  </div>
</footer>

<style>
  /* ===== FOOTER VARIABLES ===== */
  .site-footer {
    --footer-bg: #1a193c;
    --footer-bg-darker: #141331;
    --footer-text: #cbd5e1;
    --footer-heading-color: #ffffff;
    --footer-link-hover: #fde047;
    --footer-border: rgba(255,255,255,0.08);
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--footer-text);
    background: var(--footer-bg);
  }

  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* ===== TOP BAR: Campus addresses ===== */
  .footer-top-bar {
    background: var(--footer-bg-darker);
    border-bottom: 1px solid var(--footer-border);
    padding: 1.5rem 0;
  }

  .campus-bar {
    display: grid;
    grid-template-columns: 140px 1fr 1fr 1fr;
    gap: 2rem;
    align-items: center;
  }

  .footer-logo-img {
    height: 70px;
    width: auto;
    object-fit: contain;
    filter: brightness(0) invert(1);
    opacity: 0.95;
  }

  .campus-address-col {
    font-size: 0.82rem;
    color: #94a3b8;
    line-height: 1.5;
  }

  .campus-address-col strong {
    color: #e2e8f0;
    font-weight: 600;
  }

  .hotline-text {
    display: inline-block;
    margin-top: 0.25rem;
  }

  .hotline-link {
    color: #fde047;
    font-weight: 700;
    text-decoration: none;
    transition: color 0.2s;
  }

  .hotline-link:hover {
    color: #ffffff;
  }

  /* ===== MAIN FOOTER: 5 columns ===== */
  .footer-main {
    padding: 3rem 0 2.5rem;
  }

  .footer-5col {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.2fr 1.5fr;
    gap: 2.5rem;
  }

  .footer-heading {
    font-size: 1rem;
    font-weight: 600;
    color: var(--footer-heading-color);
    margin: 0 0 1.25rem 0;
    padding: 0;
  }

  .footer-col--intro .footer-intro-text {
    color: #94a3b8;
    font-size: 0.82rem;
    line-height: 1.65;
    margin: 0 0 1.25rem 0;
  }

  .social-icons {
    display: flex;
    gap: 0.75rem;
  }

  .social-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(255,255,255,0.08);
    color: #cbd5e1;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .social-icons a:hover {
    background: #fde047;
    color: #1a193c;
    transform: translateY(-2px);
  }

  /* Links */
  .footer-links {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.65rem;
  }

  .footer-links a {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.85rem;
    transition: color 0.2s, transform 0.2s;
    display: inline-block;
  }

  .footer-links a:hover {
    color: var(--footer-link-hover);
    transform: translateX(3px);
  }

  /* ===== COPYRIGHT ===== */
  .footer-copyright {
    border-top: 1px solid var(--footer-border);
    padding: 1.25rem 0;
    text-align: center;
  }

  .footer-copyright p {
    margin: 0;
    color: #64748b;
    font-size: 0.82rem;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .campus-bar {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    .campus-logo-col {
      grid-column: 1 / -1;
      text-align: center;
    }
    .footer-5col {
      grid-template-columns: 1fr 1fr 1fr;
      gap: 2rem;
    }
    .footer-col--intro {
      grid-column: 1 / -1;
    }
  }

  @media (max-width: 768px) {
    .campus-bar {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-5col {
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .footer-5col {
      grid-template-columns: 1fr;
    }
  }
</style>
