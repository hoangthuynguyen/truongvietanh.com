---
// src/components/HeaderBase.astro
const logoUrl = "/logo-vietanh.png";
---

<div class="top-bar">
  <div class="cf-container top-bar-inner">
    <div class="top-left">
      <span class="icon-text text-nowrap">
         <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"></path></svg>
         Hotline: 0916 961 409
      </span>
      <span class="icon-text d-none-mo text-nowrap" style="margin-left: 1.5rem;">
         <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg>
         Zalo: 0916 961 409
      </span>
    </div>
    <div class="top-right d-none-mo">
      <button aria-label="Tìm kiếm trên website" class="search-btn">
         <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </button>
      <a href="/tuyen-sinh" class="btn-yellow">Tư vấn tuyển sinh ↗</a>
    </div>
  </div>
</div>

<header class="main-header">
  <nav class="nav-grid">
     <ul class="nav-links left-nav">
       <li><a href="/">Trang Chủ</a></li>
       <li class="has-dropdown"><a href="/gioi-thieu">Giới Thiệu</a></li>
       <li class="has-dropdown">
         <a href="/cap-hoc">Chương Trình ▾</a>
         <ul class="dropdown-menu">
           <li><a href="/mam-non">Mầm Non</a></li>
           <li><a href="/tieu-hoc">Tiểu Học</a></li>
           <li><a href="/trung-hoc-co-so">THCS</a></li>
           <li><a href="/trung-hoc-pho-thong">THPT</a></li>
           <li><a href="/ngoai-khoa">Ngoại Khóa</a></li>
         </ul>
       </li>
       <li><a href="/tuyen-sinh">Tuyển Sinh</a></li>
     </ul>
     
     <div class="header-logo text-center">
       <a href="/">
          <img src={logoUrl} alt="Trường Liên Cấp Việt Anh" class="official-logo" />
       </a>
     </div>
     
     <ul class="nav-links right-nav">
       <li><a href="/hoc-thuat">Học Thuật</a></li>
       <li><a href="/dich-vu">Dịch Vụ</a></li>
       <li><a href="/tin-tuc">Tin Tức</a></li>
       <li><a href="/lien-he">Liên hệ</a></li>
     </ul>
  </nav>
</header>

<style>
  /* UTILS for header */
  .cf-container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .text-center { text-align: center; }
  .text-nowrap { white-space: nowrap; }

  /* TOP BAR */
  .top-bar { background: var(--cf-blue, #1a193c); color: #e2e8f0; font-size: 0.85rem; padding: 0.4rem 0; font-weight: 400; font-family: 'Inter', sans-serif;}
  .top-bar-inner { display: flex; justify-content: space-between; align-items: center; }
  .top-left .icon-text { display: inline-flex; align-items: center; gap: 0.4rem; }
  .top-right { display: flex; align-items: center; gap: 1rem; }
  .search-btn { background: none; border: none; color: #fff; cursor: pointer; display: flex; align-items: center; }
  .btn-yellow { background: var(--pri-yellow, #fde047); color: #000; font-weight: 600; text-decoration: none; padding: 0.4rem 1rem; border-radius:3px; font-size: 0.8rem; border: none; cursor:pointer;}
  .btn-yellow:hover { background: #fef08a; }

  /* MAIN NAV */
  .main-header { background: #ffffff; border-bottom: 1px solid #e2e8f0; position: sticky; top: 0; z-index: 100; box-shadow: 0 4px 15px rgba(0,0,0,0.03); font-family: 'Inter', sans-serif; }
  .nav-grid { max-width: 1200px; margin: 0 auto; padding: 0 1rem; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; min-height: 80px; gap: 1rem; }
  
  .nav-links { list-style: none; padding: 0; margin: 0; display: flex; gap: 1.25rem; align-items: center; }
  .right-nav { justify-content: flex-start; }
  .left-nav { justify-content: flex-end; }
  .nav-links li { position: relative; }
  .nav-links a { text-decoration: none; color: var(--pri-blue, #232252); font-weight: 600; font-size: 0.9rem; white-space: nowrap; transition: color 0.2s; display: flex; align-items: center; padding: 1.5rem 0; }
  .nav-links a:hover { color: var(--cf-blue, #1a193c); }

  /* DROPDOWN */
  .dropdown-menu { position: absolute; top: 100%; left: 0; background: #ffffff; min-width: 180px; box-shadow: 0 10px 25px rgba(0,0,0,0.1); border-radius: 4px; opacity: 0; visibility: hidden; transform: translateY(10px); transition: all 0.2s ease; border: 1px solid #f1f5f9; padding: 0.5rem 0; display: flex; flex-direction: column; z-index: 200; }
  .has-dropdown:hover .dropdown-menu { opacity: 1; visibility: visible; transform: translateY(0); }
  .dropdown-menu a { padding: 0.6rem 1.25rem; font-weight: 500; font-size: 0.85rem; color: var(--text-dark, #0f172a); border-left: 3px solid transparent; }
  .dropdown-menu a:hover { background: var(--bg-gray, #f8fafc); color: var(--cf-blue, #1a193c); border-left-color: var(--cf-blue, #1a193c); }

  /* LOGO ENLARGED */
  .header-logo { display: flex; justify-content: center; width: 100%; }
  .official-logo { height: 120px; object-fit: contain; }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .nav-grid { grid-template-columns: 1fr auto; justify-content: space-between; }
    .left-nav, .right-nav { display: none; }
  }

  @media (max-width: 768px) {
    .d-none-mo { display: none; }
  }
</style>
