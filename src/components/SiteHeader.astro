---
import { adminUrl, contactLinks, mainNav } from '../lib/site-content';

type Props = {
  currentPath: string;
  siteUrl?: string;
  navItems?: { label: string; href: string }[];
  showCmsLink?: boolean;
};

const { currentPath, siteUrl = '/', navItems = mainNav, showCmsLink = false } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand-lockup" href={siteUrl}>
      <span class="brand-lockup__mark">VA</span>
      <span class="brand-lockup__text">
        <strong>Trường Việt Anh</strong>
        <small>Hệ thống giáo dục liên cấp song ngữ</small>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Điều hướng chính">
      {navItems.map((item) => {
        const active =
          item.href === '/'
            ? currentPath === '/'
            : item.href.startsWith('#')
              ? false
              : currentPath === item.href || currentPath.startsWith(`${item.href}/`);

        return (
          <a class={active ? 'is-active' : ''} href={item.href}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="site-header__actions">
      <a class="link-pill" href={contactLinks.phoneHref}>{contactLinks.phoneDisplay}</a>
      <a class="link-pill link-pill--ghost" href={contactLinks.zaloHref} target="_blank" rel="noreferrer">
        Zalo
      </a>
      {showCmsLink && (
        <a class="link-pill link-pill--ghost" href={adminUrl} target="_blank" rel="noreferrer" aria-label="Vào CMS Directus">
          CMS
        </a>
      )}
    </div>
  </div>
</header>
