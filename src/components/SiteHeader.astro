---
import { adminUrl, contactLinks, mainNav } from '../lib/site-content';

type Props = {
  currentPath: string;
  siteUrl?: string;
  navItems?: Array<{
    label: string;
    href: string;
    children?: Array<{
      label: string;
      href: string;
    }>;
  }>;
  showCmsLink?: boolean;
};

const { currentPath, siteUrl = '/', navItems = mainNav, showCmsLink = false } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand-lockup" href={siteUrl}>
      <span class="brand-lockup__mark">VA</span>
      <span class="brand-lockup__text">
        <strong>Trường Việt Anh</strong>
        <small>Hệ thống giáo dục liên cấp song ngữ</small>
      </span>
    </a>

    <nav class="primary-nav" aria-label="Điều hướng chính">
      {navItems.map((item) => {
        const active =
          item.href === '/'
            ? currentPath === '/'
            : item.href.startsWith('#')
              ? false
              : currentPath === item.href || currentPath.startsWith(`${item.href}/`);

        if (item.children) {
          const isChildActive = item.children.some(child => currentPath === child.href || currentPath.startsWith(`${child.href}/`));
          return (
            <div class={`nav-dropdown ${isChildActive ? 'is-active-dropdown' : ''}`}>
              <span class="nav-dropdown-trigger">
                {item.label}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </span>
              <div class="nav-dropdown-menu">
                {item.children.map(child => (
                  <a class={currentPath === child.href || currentPath.startsWith(`${child.href}/`) ? 'is-active' : ''} href={child.href}>
                    {child.label}
                  </a>
                ))}
              </div>
            </div>
          );
        }

        return (
          <a class={active ? 'is-active' : ''} href={item.href}>
            {item.label}
          </a>
        );
      })}
    </nav>

    <div class="site-header__actions">
      <a class="link-pill" href={contactLinks.phoneHref}>{contactLinks.phoneDisplay}</a>
      <a class="link-pill link-pill--ghost" href={contactLinks.zaloHref} target="_blank" rel="noreferrer">
        Zalo
      </a>
      {showCmsLink && (
        <a class="link-pill link-pill--ghost" href={adminUrl} target="_blank" rel="noreferrer" aria-label="Vào CMS Directus">
          CMS
        </a>
      )}
    </div>
  </div>
</header>
