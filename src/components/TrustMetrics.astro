---
type MetricItem = {
  number: string | number;
  label: string;
};

type Props = {
  metrics: MetricItem[];
  title?: string;
};

const { metrics, title } = Astro.props;
---

<div class="trust-metrics-wrapper">
  {title && (
    <h2 class="trust-metrics-title">{title}</h2>
  )}

  <div class="trust-metrics-grid">
    {metrics.map((metric) => (
      <div class="metric-item">
        <div class="metric-number">{metric.number}</div>
        <div class="metric-label">{metric.label}</div>
      </div>
    ))}
  </div>
</div>

<style is:inline>
  .trust-metrics-wrapper { width: 100%; text-align: center; color: white; }
  .trust-metrics-title { font-family: "Montserrat", sans-serif; font-size: clamp(1.25rem, 3vw, 1.75rem); font-weight: 700; margin-bottom: 2rem; color: white; }
  .trust-metrics-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 2rem; align-items: center; }
  .metric-item { display: flex; flex-direction: column; align-items: center; gap: 0.5rem; }
  .metric-number { font-family: "Montserrat", sans-serif; font-size: clamp(2rem, 6vw, 3.5rem); font-weight: 800; line-height: 1; color: #E8792B; text-shadow: 0 2px 4px rgba(0, 0, 0, 0.2); }
  .metric-label { font-size: clamp(0.875rem, 2vw, 1.125rem); font-weight: 500; line-height: 1.3; opacity: 0.95; }
  @media (max-width: 768px) { .trust-metrics-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } .metric-number { font-size: 2rem; } .metric-label { font-size: 0.875rem; } }
  @media (max-width: 480px) { .trust-metrics-title { margin-bottom: 1.5rem; } .trust-metrics-grid { gap: 1rem; } .metric-item { gap: 0.25rem; } .metric-number { font-size: 1.75rem; } .metric-label { font-size: 0.75rem; } }
</style>
