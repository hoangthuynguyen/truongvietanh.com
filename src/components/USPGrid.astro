---
type USPItem = {
  icon: string;
  text: string;
};

type Props = {
  title?: string;
  items: USPItem[];
};

const { title = 'Tại sao chọn Trường Việt Anh?', items } = Astro.props;
---

<div class="usp-grid-wrapper">
  {title && (
    <h2 class="usp-grid-title">{title}</h2>
  )}

  <div class="usp-grid">
    {items.map((item) => (
      <div class="usp-item">
        <div class="usp-icon">
          {typeof item.icon === 'string' && item.icon.startsWith('<') ? (
            <span set:html={item.icon} />
          ) : (
            <span>{item.icon}</span>
          )}
        </div>
        <p class="usp-text">{item.text}</p>
      </div>
    ))}
  </div>
</div>

<style is:inline>
  .usp-grid-wrapper { width: 100%; }
  .usp-grid-title { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 2rem; text-align: center; color: #1F4E79; }
  .usp-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .usp-item { display: flex; flex-direction: column; align-items: center; text-align: center; padding: 1.5rem; border-radius: 12px; background-color: white; border: 1px solid #e0e0e0; transition: all 0.3s ease; }
  .usp-item:hover { border-color: #E8792B; box-shadow: 0 8px 20px rgba(232, 121, 43, 0.12); transform: translateY(-4px); }
  .usp-icon { display: inline-flex; align-items: center; justify-content: center; width: 60px; height: 60px; margin-bottom: 1rem; font-size: 2.5rem; line-height: 1; }
  .usp-icon svg { width: 48px; height: 48px; color: #E8792B; stroke-width: 1.5; }
  .usp-text { font-size: 1rem; font-weight: 500; line-height: 1.5; color: #1a1a1a; margin: 0; }
  @media (max-width: 768px) { .usp-grid-title { margin-bottom: 1.5rem; } .usp-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; } .usp-item { padding: 1.25rem; } .usp-icon { width: 50px; height: 50px; font-size: 2rem; } .usp-text { font-size: 0.9rem; } }
  @media (max-width: 480px) { .usp-grid { grid-template-columns: 1fr; gap: 1rem; } .usp-item { padding: 1rem; } .usp-icon { width: 45px; height: 45px; font-size: 1.75rem; margin-bottom: 0.75rem; } .usp-text { font-size: 0.85rem; } }
</style>
