---
import '../styles/global.css';

type Props = {
  title?: string;
  description?: string;
  canonical?: string;
  noindex?: boolean;
};

const {
  title = 'truongvietanh.com',
  description = 'Astro frontend connected to Directus and ready for Cloudflare Workers.',
  canonical,
  noindex = canonical?.includes('staging.') || canonical?.includes('workers.dev'),
} = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#123967" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;600;700;800&family=Montserrat:wght@600;700;800&display=swap"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    {canonical && <meta property="og:url" content={canonical} />}
  </head>
  <body>
    <slot />
  </body>
</html>
