---
import BlocksRenderer from '../components/BlocksRenderer.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getAllContentPageSlugs, getContentPageBySlug } from '../lib/content-pages';
import { defaultSiteUrl } from '../lib/site-content';

export async function getStaticPaths() {
  const slugs = await getAllContentPageSlugs();

  return slugs.map((slug) => ({
    params: { slug },
  }));
}

const slug = Astro.params.slug;
const page = slug ? await getContentPageBySlug(slug) : null;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || defaultSiteUrl;

if (!page) {
  Astro.response.status = 404;
}

const canonical = page ? `${siteUrl.replace(/\/$/, '')}/${page.slug}` : undefined;
const title = page?.seoTitle || page?.title || 'Khong tim thay trang';
const description =
  page?.seoDescription ||
  page?.description ||
  'Trang ban dang tim khong ton tai hoac chua duoc dong bo tu Directus.';
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={page?.ogImage || undefined}>
  <div class={`site-shell site-shell--${page?.theme || 'brand'}`}>
    <SiteHeader currentPath={`/${slug || ''}`} siteUrl="/" showCmsLink={page?.showCmsLink} />

    <main class="page-flow">
      {page ? (
        <BlocksRenderer blocks={page.blocks} />
      ) : (
        <section class="section-block empty-state">
          <div class="section-heading">
            <p class="section-eyebrow">404</p>
            <h1>Trang nay chua co trong Directus hoac trong bo du lieu fallback.</h1>
            <p class="section-intro">
              Neu ban vua tao page trong CMS, hay kiem tra lai `slug`, `status=published`, va cac ban ghi `page_blocks`.
            </p>
          </div>

          <div class="cta-row">
            <a class="button button--primary" href="/">
              Ve trang chu
            </a>
            <a class="button button--ghost" href="/api/health.json">
              Kiem tra ket noi Directus
            </a>
          </div>
        </section>
      )}
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
