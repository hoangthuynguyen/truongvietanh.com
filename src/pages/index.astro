---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomepageState } from '../lib/directus';

const state = await getHomepageState();
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://staging.truongvietanh.com';
const adminUrl = import.meta.env.PUBLIC_DIRECTUS_ADMIN_URL?.trim() || 'https://admin.truongvietanh.com/admin';
const posts = state.posts.slice(0, 3);

const navItems = [
  { label: 'Giới Thiệu', href: 'https://truongvietanh.com/gioi-thieu/' },
  { label: 'Chương Trình', href: 'https://truongvietanh.com/tieu-hoc-viet-anh/' },
  { label: 'Học Bổng', href: 'https://truongvietanh.com/hoc-bong/' },
  { label: 'Liên Hệ', href: 'https://truongvietanh.com/lien-he/' },
];

const programs = [
  {
    title: 'Mầm non',
    detail: 'Môi trường song ngữ, nền nếp và phát triển cảm xúc cho giai đoạn đầu đời.',
  },
  {
    title: 'Tiểu học',
    detail: 'Cân bằng giữa học thuật, tiếng Anh và kỹ năng tự học hằng ngày.',
  },
  {
    title: 'THCS - THPT',
    detail: 'Định hướng chuyên Anh, bứt tốc học thuật và chuẩn bị cho giai đoạn đại học.',
  },
];
---

<BaseLayout
  title="Trường Việt Anh | Staging Trên Cloudflare Workers"
  description="Bản staging nhẹ và nhanh cho trang chủ Trường Việt Anh, build tĩnh bằng Astro và lấy nội dung từ Directus."
>
  <main class="shell">
    <header class="topbar panel">
      <a class="brand" href={siteUrl}>
        <span class="brand__mark">VA</span>
        <span class="brand__text">
          <strong>Trường Việt Anh</strong>
          <small>Staging trên Cloudflare Workers</small>
        </span>
      </a>

      <nav class="nav">
        {navItems.map((item) => (
          <a href={item.href} target="_blank" rel="noreferrer">{item.label}</a>
        ))}
      </nav>

      <div class="topbar__actions">
        <a class="link-soft" href="tel:0916961409">0916 961 409</a>
        <a class="button button--ghost" href={adminUrl} target="_blank" rel="noreferrer">CMS</a>
      </div>
    </header>

    <section class="hero panel">
      <div class="hero__copy">
        <p class="eyebrow">Staging đã live</p>
        <h1>Trang chủ nhẹ, nhanh và đủ sát tinh thần của truongvietanh.com.</h1>
        <p class="lede">
          Bản này ưu tiên tốc độ tải: không popup, không slider nặng, không script theo dõi phức tạp.
          Nội dung tin tức vẫn lấy từ Directus ở bước build để bạn có thể đăng bài và xem kết quả ngay trên staging.
        </p>

        <div class="badges">
          <span class={`badge ${state.configured ? 'badge--ok' : 'badge--warn'}`}>
            {state.configured ? 'Directus đã kết nối' : 'Thiếu cấu hình Directus'}
          </span>
          <span class="badge">{posts.length} bài viết</span>
          <span class="badge">Static Astro + Workers</span>
        </div>

        <div class="hero__actions">
          <a class="button button--primary" href="https://truongvietanh.com/lien-he/" target="_blank" rel="noreferrer">Tư vấn tuyển sinh</a>
          <a class="button button--ghost" href={adminUrl} target="_blank" rel="noreferrer">Đăng nhập quản trị</a>
        </div>
      </div>

      <div class="hero__stats">
        <div class="stat-card">
          <span>Hotline</span>
          <strong>0916 961 409</strong>
        </div>
        <div class="stat-card">
          <span>URL staging</span>
          <strong>staging.truongvietanh.com</strong>
        </div>
        <div class="stat-card">
          <span>CMS</span>
          <strong>Directus trên VPS Contabo</strong>
        </div>
      </div>
    </section>

    <section class="panel section">
      <div class="section-head">
        <div>
          <p class="eyebrow">Chương trình đào tạo</p>
          <h2>Khối nội dung chính của trường được giữ lại theo phiên bản tối giản.</h2>
        </div>
      </div>

      <div class="card-grid">
        {programs.map((program) => (
          <article class="card">
            <h3>{program.title}</h3>
            <p>{program.detail}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="panel section section--split">
      <article class="mini-panel">
        <p class="eyebrow">Ưu tiên hiện tại</p>
        <h2>Nhẹ và nhanh trước, mở rộng sau.</h2>
        <ul class="checklist">
          <li>Không tải ảnh lớn ở đầu trang</li>
          <li>Không dùng JS client không cần thiết</li>
          <li>HTML nhỏ, CSS gọn, ít request</li>
          <li>Tin tức được build sẵn từ Directus</li>
        </ul>
      </article>

      <article class="mini-panel mini-panel--accent">
        <p class="eyebrow">Quản trị nội dung</p>
        <h2>Đăng bài trong Directus, redeploy staging để xem kết quả.</h2>
        <p>
          URL quản trị hiện tại là <code>{adminUrl}</code>. Frontend staging sẽ dùng domain quản trị này
          thay cho IP thô để biên tập nội dung thuận tiện hơn.
        </p>
      </article>
    </section>

    <section class="panel section">
      <div class="section-head section-head--split">
        <div>
          <p class="eyebrow">Tin mới nhất</p>
          <h2>Phần này đang lấy trực tiếp từ Directus để bạn thử quy trình biên tập.</h2>
        </div>
        <a class="link-strong" href={adminUrl} target="_blank" rel="noreferrer">Vào Directus Admin</a>
      </div>

      {
        state.error ? (
          <p class="notice">{state.error}</p>
        ) : posts.length > 0 ? (
          <div class="card-grid">
            {posts.map((post) => (
              <article class="card card--post">
                <p class="post-date">
                  {post.published_at ? new Date(post.published_at).toLocaleDateString('vi-VN') : 'Chưa có ngày đăng'}
                </p>
                <h3>{post.title}</h3>
                <p>{post.excerpt || post.content || 'Thêm mô tả ngắn trong Directus để card đẹp hơn.'}</p>
                <code>/{post.slug}</code>
              </article>
            ))}
          </div>
        ) : (
          <p class="notice">Hiện chưa có bài viết nào được publish trong Directus.</p>
        )
      }
    </section>
  </main>
</BaseLayout>
