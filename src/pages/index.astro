---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { admissionsCards, defaultSiteUrl, levelCards, launchPages } from '../lib/site-content';
import { getHomepageState } from '../lib/directus';

const state = await getHomepageState();
const siteUrl = import.meta.env.PUBLIC_SITE_URL || defaultSiteUrl;
const posts = state.posts.slice(0, 3);
---

<BaseLayout
  title="Truong Viet Anh | Wave 1 tren staging"
  description="Homepage wave 1 cua Truong Viet Anh tren Astro, duoc xay de dieu phoi traffic vao pillars, hoc phi va admissions hub."
  canonical={siteUrl}
>
  <div class="site-shell site-shell--home">
    <SiteHeader currentPath="/" siteUrl="/" />

    <main class="page-flow">
      <section class="hero-block hero-block--home">
        <div class="hero-block__main">
          <p class="section-eyebrow">Class Homepage</p>
          <h1>10 trang dau tien da duoc dong bo theo SEO architecture, launch tren staging truoc khi scale them campus va landings.</h1>
          <p class="hero-copy">
            Homepage nay khong con la mot trang placeholder. No dong vai tro Grand Central Station: dieu phoi traffic
            ve 4 pillar pages, trang admissions, money page va 3 trang brand authority de phuc vu ca SEO lan conversion.
          </p>

          <div class="badge-row">
            <span class="badge">Wave 1 launch</span>
            <span class="badge badge--soft">Homepage + 9 strategic pages</span>
            <span class="badge badge--soft">Astro static + Cloudflare Pages</span>
          </div>

          <div class="cta-row">
            <a class="button button--primary" href="/tuyen-sinh">Bat dau tu Admissions Hub</a>
            <a class="button button--ghost" href="/hoc-phi">Mo Money Page</a>
          </div>
        </div>

        <aside class="hero-block__aside">
          <p class="aside-eyebrow">Quick routes</p>
          <h2>3 duong vao co y nghia nhat tren staging hien tai.</h2>
          <div class="quick-stack">
            {admissionsCards.map((card) => (
              <a class="quick-card" href={card.href}>
                <p class="card-eyebrow">{card.eyebrow}</p>
                <h3>{card.title}</h3>
                <p>{card.body}</p>
              </a>
            ))}
          </div>
        </aside>
      </section>

      <section class="section-block section-block--stats">
        <div class="section-heading">
          <p class="section-eyebrow">Launch metrics</p>
          <h2>Trang chu nay duoc viet de giai bai toan route traffic, khong chi de “gioi thieu trang web”.</h2>
        </div>

        <div class="stats-grid">
          <article class="stat-tile">
            <strong>10</strong>
            <span>URL core da len staging trong dot dau</span>
          </article>
          <article class="stat-tile">
            <strong>4</strong>
            <span>Pillar pages cho 4 cap hoc chinh</span>
          </article>
          <article class="stat-tile">
            <strong>3</strong>
            <span>Trang authority de neo trust truoc khi so sanh hoc phi</span>
          </article>
          <article class="stat-tile">
            <strong>2</strong>
            <span>Conversion hubs cho tuyen sinh va money intent</span>
          </article>
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Wave 1 pages</p>
          <h2>Ban do launch cho dot dau tien da co du route, du template logic va du internal links.</h2>
          <p class="section-intro">
            Cac page duoi day duoc uu tien theo dung tinh than trong bo tai lieu: brand core, authority assets,
            level pillars va conversion hubs.
          </p>
        </div>

        <div class="link-grid">
          {launchPages.map((page) => (
            <a class="link-card" href={page.href}>
              <p class="card-eyebrow">{page.eyebrow}</p>
              <h3>{page.title}</h3>
              <p>{page.body}</p>
              <span>Mo trang</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Template library</p>
          <h2>Toan bo 16 template classes da co 1 sample page rieng de review tren staging.</h2>
          <p class="section-intro">
            Day la noi doi team co the xem tung class theo huong block order, brand guideline, SEO checklist va goi y nang cao truoc khi doi sang content that trong Directus.
          </p>
        </div>

        <div class="card-grid card-grid--3">
          <article class="content-card">
            <p class="card-eyebrow">Performance</p>
            <h3>Landing ads va local conversion</h3>
            <p>Fee capture, campus tour, open day, hoc thu va TikTok mobile-first deu co sample rieng.</p>
            <a class="card-link" href="/mau-template/">Mo thu vien template</a>
          </article>
          <article class="content-card">
            <p class="card-eyebrow">Authority</p>
            <h3>SEO / pillar / local trust</h3>
            <p>Level pillar, campus profile va local intent pages duoc review theo dung vai tro trong architecture.</p>
            <a class="card-link" href="/mau-template/class-level-pillar/">Xem sample authority</a>
          </article>
          <article class="content-card">
            <p class="card-eyebrow">System</p>
            <h3>Thank-you, objection, referral</h3>
            <p>Nhung class thuong bi bo quen nay da co sample va checklist de doi team khong “lam cho co”.</p>
            <a class="card-link" href="/mau-template/class-smart-thank-you/">Xem sample system</a>
          </article>
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Core SEO pillars</p>
          <h2>Bon pillar pages duoc viet de bat keyword cap hoc va day user ve dung hanh dong.</h2>
          <p class="section-intro">
            Moi pillar page deu co vai tro ro: authority, internal link hub, FAQ support va CTA mem sang admissions
            hoac money page.
          </p>
        </div>

        <div class="link-grid">
          {levelCards.map((card) => (
            <a class="link-card" href={card.href}>
              <p class="card-eyebrow">{card.eyebrow}</p>
              <h3>{card.title}</h3>
              <p>{card.body}</p>
              <span>Mo pillar</span>
            </a>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Brand authority</p>
          <h2>Ba trang authority duoc dat canh nhau de homepage co du “do sau” truoc khi user sang conversion.</h2>
          <p class="section-intro">
            Cau truc nay giup homepage khong bi qua thương mai: phu huynh co du duong doc sâu truoc khi sang Hoc Phi
            hay admissions.
          </p>
        </div>

        <div class="card-grid card-grid--3">
          <article class="content-card">
            <p class="card-eyebrow">Brand Core</p>
            <h3>Gioi Thieu</h3>
            <p>Trang ke cau chuyen thuong hieu, giai thich vi sao Viet Anh ton tai va ai la doi tuong phu hop.</p>
            <a class="card-link" href="/gioi-thieu">Xem trang Gioi Thieu</a>
          </article>
          <article class="content-card">
            <p class="card-eyebrow">Thought Leadership</p>
            <h3>Triet Ly Giao Duc</h3>
            <p>Trang giai thich tinh than vui ve va thuc dung, dung de tang trust truoc giai doan so sanh.</p>
            <a class="card-link" href="/triet-ly-giao-duc">Doc triet ly</a>
          </article>
          <article class="content-card">
            <p class="card-eyebrow">Signature Asset</p>
            <h3>He Thong PDR</h3>
            <p>Trang moat quan trong nhat sau homepage, cho thay cach nha truong bien triet ly thanh he thong hoc tap.</p>
            <a class="card-link" href="/he-thong-pdr">Kham pha PDR</a>
          </article>
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">CMS pulse</p>
          <h2>Khung build van giu ket noi Directus de doi bien tap co mot noi nhin noi dung moi nhat.</h2>
          <p class="section-intro">
            Day la strip nhe de giu lien ket voi CMS. No khong canh tranh vai tro voi homepage, ma giup kiem tra quy
            trinh Directus khi can.
          </p>
        </div>

        {
          state.error ? (
            <article class="notice-card">
              <h3>Directus tam thoi chua tra du lieu</h3>
              <p>{state.error}</p>
            </article>
          ) : posts.length > 0 ? (
            <div class="card-grid card-grid--3">
              {posts.map((post) => (
                <article class="content-card">
                  <p class="card-eyebrow">Directus post</p>
                  <h3>{post.title}</h3>
                  <p>{post.excerpt || post.content || 'Bo sung excerpt trong Directus de strip nay day dan hon.'}</p>
                  <span class="card-meta">
                    {post.published_at
                      ? new Date(post.published_at).toLocaleDateString('vi-VN')
                      : 'Chua co ngay dang'}
                  </span>
                </article>
              ))}
            </div>
          ) : (
            <article class="notice-card">
              <h3>Chua co bai viet duoc publish</h3>
              <p>Strip nay se tu day len khi doi bien tap publish post trong Directus.</p>
            </article>
          )
        }
      </section>

      <section class="cta-banner">
        <div>
          <p class="section-eyebrow">Next build wave</p>
          <h2>Buoc tiep theo la them campus pages, fee capture landings va local SEO pages.</h2>
          <p>
            Nhưng trước mắt, staging đã có đủ khung để review structure, content direction và internal linking cho phase
            launch đầu tiên.
          </p>
        </div>

        <div class="cta-row">
          <a class="button button--primary" href="/tuyen-sinh">Review Admissions Hub</a>
          <a class="button button--ghost" href="/trung-hoc-pho-thong">Review THPT Pillar</a>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
