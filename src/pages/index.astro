---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomepageState } from '../lib/directus';

const state = await getHomepageState();
const siteUrl = import.meta.env.PUBLIC_SITE_URL || 'https://truongvietanh.com';
---

<BaseLayout
  title="truongvietanh.com | Astro + Directus + Cloudflare Workers"
  description="Frontend Astro static build tren Cloudflare Workers ket noi Directus backend bang bien moi truong."
>
  <main class="shell">
    <section class="hero card">
      <div class="eyebrow">Truong Viet Anh</div>
      <h1>Astro frontend da san sang noi voi Directus backend tren Cloudflare Workers.</h1>
      <p class="lede">
        Frontend nay build thanh static assets va deploy len Cloudflare Workers.
        Astro doc du lieu tu Directus qua SDK trong luc build.
        Backend Directus can chay o mot host rieng, sau do frontend se goi qua
        <code>PUBLIC_DIRECTUS_URL</code> de render san noi dung.
      </p>

      <div class="pill-row">
        <span class={`pill ${state.configured ? 'pill-ok' : 'pill-warn'}`}>
          {state.configured ? 'Directus URL da cau hinh' : 'Thieu Directus URL'}
        </span>
        <span class={`pill ${state.usingToken ? 'pill-ok' : 'pill-muted'}`}>
          {state.usingToken ? 'Dang dung server token' : 'Dang dung public permissions'}
        </span>
        <span class="pill pill-muted">Site URL: {siteUrl}</span>
      </div>
    </section>

    <section class="grid">
      <article class="card">
        <h2>Trang thai ket noi</h2>
        <dl class="meta">
          <div>
            <dt>Frontend</dt>
            <dd>Astro static + Workers Static Assets</dd>
          </div>
          <div>
            <dt>Backend</dt>
            <dd>Directus REST API</dd>
          </div>
          <div>
            <dt>Directus URL</dt>
            <dd>{state.url ?? 'Chua cau hinh'}</dd>
          </div>
          <div>
            <dt>So bai viet doc duoc</dt>
            <dd>{state.posts.length}</dd>
          </div>
        </dl>

        {
          state.error && (
            <p class="notice notice-warn">
              {state.error}
            </p>
          )
        }
      </article>

      <article class="card">
        <h2>Checklist deploy</h2>
        <ol class="steps">
          <li>Chay Directus rieng bang Docker hoac Directus Cloud.</li>
          <li>Set <code>PUBLIC_DIRECTUS_URL</code> va <code>DIRECTUS_TOKEN</code> trong Workers Builds build environment.</li>
          <li>Worker staging dung file <code>wrangler.staging.jsonc</code> va gan domain <code>staging.truongvietanh.com</code>.</li>
          <li>Worker production dung file <code>wrangler.jsonc</code> va gan domain <code>truongvietanh.com</code>, <code>www.truongvietanh.com</code>.</li>
        </ol>
      </article>
    </section>

    <section class="card">
      <div class="section-head">
        <div>
          <div class="eyebrow">Noi dung tu Directus</div>
          <h2>Danh sach bai viet</h2>
        </div>
        <a class="ghost-link" href={state.url ?? '#'} target="_blank" rel="noreferrer">
          Mo Directus
        </a>
      </div>

      {
        state.posts.length > 0 ? (
          <div class="posts">
            {state.posts.map((post) => (
              <article class="post-card">
                <p class="post-date">{post.published_at ? new Date(post.published_at).toLocaleDateString('vi-VN') : 'Chua co ngay dang'}</p>
                <h3>{post.title}</h3>
                <p>{post.excerpt || post.content || 'Them du lieu trong collection posts de hien thi tai day.'}</p>
                <code>/{post.slug}</code>
              </article>
            ))}
          </div>
        ) : (
          <div class="empty-state">
            <p>Chua co bai viet nao hien len tu Directus.</p>
            <p>Tao collection <code>posts</code> voi cac field <code>slug</code>, <code>title</code>, <code>excerpt</code>, <code>content</code>, <code>published_at</code>, <code>status</code>.</p>
          </div>
        )
      }
    </section>
  </main>
</BaseLayout>
