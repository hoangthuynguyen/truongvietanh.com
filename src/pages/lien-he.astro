---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeaderBase from '../components/HeaderBase.astro';
import FooterBase from '../components/FooterBase.astro';
---
<BaseLayout title="Liên Hệ | Trường Liên Cấp Việt Anh" description="Cổng liên hệ chính thức của Hệ thống giáo dục trường Việt Anh.">
  <div class="cf-layout page-wrapper">
    <HeaderBase />
    
    <section class="page-hero">
      <div class="cf-container text-center">
        <h1 class="page-title">Liên Hệ Trường Việt Anh</h1>
        <p class="page-desc">Chúng tôi ở ngay đây để hỗ trợ phụ huynh mọi thông tin cần thiết nhất.</p>
      </div>
    </section>

    <section class="page-content">
      <div class="cf-container max-w-900 text-center">
        <h2>Kết Nối Với Chúng Tôi</h2>
        <p>Trung Tâm Tư Vấn Chọn Lộ Trình - Hệ Thống Trường Liên Cấp Việt Anh</p>

        <div class="contact-methods">
           <div class="c-method">
              <h3>Hotline Tổng Đài (Cấp 1-2-3)</h3>
              <a href="tel:0916961409" class="highlight-link">0916 961 409</a>
              <p style="margin-top: 1rem; color: #475569; font-size: 0.95rem;">Zalo: <a href="https://zalo.me/0916961409" style="color: #1a193c; text-decoration: none; font-weight: bold;">0916 961 409</a></p>
           </div>
           <div class="c-method">
              <h3>Hotline Mầm Non</h3>
              <a href="tel:0774588988" class="highlight-link">0774 588 988</a>
               <p style="margin-top: 1rem; color: #475569; font-size: 0.95rem;">Zalo: <a href="https://zalo.me/0774588988" style="color: #1a193c; text-decoration: none; font-weight: bold;">0774 588 988</a></p>
           </div>
           <div class="c-method" style="grid-column: 1 / -1; margin-top: 1rem;">
             <h3>Email Hỗ Trợ Tuyển Sinh</h3>
             <a href="mailto:hoc@truongvietanh.com" class="highlight-link" style="font-size: 1.5rem;">hoc@truongvietanh.com</a>
           </div>
        </div>
      </div>
    </section>
    
    <FooterBase />
  </div>
</BaseLayout>

<style>
  .page-wrapper { font-family: 'Inter', sans-serif; color: #0f172a; background: #f8fafc; }
  .cf-container { max-width: 1200px; margin: 0 auto; padding: 0 1.5rem; }
  .max-w-900 { max-width: 900px; }
  .text-center { text-align: center; }
  
  .page-hero { background: linear-gradient(rgba(26, 25, 60, 0.8), rgba(26, 25, 60, 0.85)), url('https://truongvietanh.com/wp-content/uploads/2023/07/big-img3-scaled.jpg') center/cover no-repeat; color: #fff; padding: 8rem 0; border-bottom: 5px solid #fde047; }
  .page-title { font-size: 3rem; font-weight: 900; margin-bottom: 1rem; }
  .page-desc { font-size: 1.25rem; font-weight: 500; color: #e2e8f0; }

  .page-content { padding: 5rem 0; min-height: 400px; }
  .page-content h2 { color: #1a193c; font-size: 2.25rem; font-weight: 800; margin-bottom: 0.5rem; }
  .page-content p { font-size: 1.15rem; color: #475569; margin-bottom: 4rem; }
  
  .contact-methods { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2rem; }
  .c-method { background: #ffffff; padding: 3rem; border-radius: 12px; border: 1px solid #e2e8f0; box-shadow: 0 10px 25px rgba(0,0,0,0.03); }
  .c-method h3 { color: #475569; font-size: 1.15rem; margin-bottom: 1rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; }
  .highlight-link { color: #1a193c; font-size: 2rem; font-weight: 900; text-decoration: none; padding-bottom: 4px; border-bottom: 3px solid #fde047; transition: all 0.2s; }
  .highlight-link:hover { color: #fde047; border-bottom-color: #1a193c; }

  @media (max-width: 768px) {
    .contact-methods { grid-template-columns: 1fr; }
  }
</style>
