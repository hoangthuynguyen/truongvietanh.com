---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SiteFooter from '../../components/SiteFooter.astro';
import SiteHeader from '../../components/SiteHeader.astro';
import { defaultSiteUrl } from '../../lib/site-content';
import { getTemplateBlueprint, templateSamples } from '../../lib/template-library';

export function getStaticPaths() {
  return templateSamples.map((sample) => ({
    params: { slug: sample.slug },
    props: { sample },
  }));
}

const { sample } = Astro.props;
const siteUrl = import.meta.env.PUBLIC_SITE_URL || defaultSiteUrl;
const blueprint = getTemplateBlueprint(sample);
const canonical = `${siteUrl}/mau-template/${sample.slug}/`;
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: `${sample.classCode} - ${sample.templateClass}`,
    description: sample.description,
    url: canonical,
    inLanguage: 'vi',
    about: [
      'SEO page structure',
      'AI optimization',
      'Template-driven growth',
      'Trường Việt Anh',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      {
        '@type': 'ListItem',
        position: 1,
        name: 'Thư viện mẫu template',
        item: `${siteUrl}/mau-template/`,
      },
      {
        '@type': 'ListItem',
        position: 2,
        name: sample.templateClass,
        item: canonical,
      },
    ],
  },
];
---

<BaseLayout
  title={`${sample.classCode} | ${sample.templateClass} | Trường Việt Anh`}
  description={sample.description}
  canonical={canonical}
  structuredData={structuredData}
>
  <div class={`site-shell site-shell--${sample.theme === 'authority' ? 'pillar' : sample.theme === 'nurture' ? 'brand' : sample.theme === 'performance' ? 'admissions' : 'system'}`}>
    <SiteHeader currentPath="/mau-template" siteUrl="/" />

    <main class="page-flow">
      <section class={`hero-block template-hero template-hero--${sample.theme}`}>
        <div class="hero-block__main">
          <p class="section-eyebrow">{sample.classCode} · {sample.group}</p>
          <h1>{sample.sampleHeadline}</h1>
          <p class="hero-copy">{sample.sampleBody}</p>

          <div class="badge-row">
            <span class="badge">{sample.templateClass}</span>
            <span class="badge badge--soft">{sample.pageRole}</span>
            <span class="badge badge--soft">CTA: {sample.primaryCta}</span>
          </div>

          <div class="cta-row">
            <a class="button button--primary" href="/mau-template/">Quay về danh sách</a>
            <a class="button button--ghost" href={sample.internalLinks[0]?.href || '/'}>Xem route liên quan</a>
          </div>
        </div>

        <aside class="hero-block__aside">
          <p class="aside-eyebrow">Tổng quan template</p>
          <h2>Template này giải quyết mục tiêu nào?</h2>
          <div class="template-meta-grid">
            <div class="template-meta-card">
              <span>Đối tượng</span>
              <strong>{sample.audience}</strong>
            </div>
            <div class="template-meta-card">
              <span>Funnel</span>
              <strong>{sample.funnel}</strong>
            </div>
            <div class="template-meta-card">
              <span>Traffic</span>
              <strong>{sample.traffic}</strong>
            </div>
            <div class="template-meta-card">
              <span>CVR benchmark</span>
              <strong>{sample.cvr}</strong>
            </div>
          </div>
        </aside>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Trải nghiệm chính</p>
          <h2>Khi mở trang này, phụ huynh cần cảm thấy ngay những điều sau.</h2>
        </div>

        <div class="card-grid card-grid--2">
          {sample.previewHighlights.map((item) => (
            <article class="content-card">
              <p class="card-eyebrow">Tín hiệu cần có</p>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Cấu trúc gợi ý</p>
          <h2>Thứ tự block đề xuất để giữ đúng intent, đúng nhịp đọc và đúng CTA.</h2>
          <p class="section-intro">
            Đây là khung xương production-ready của template. Khi đưa vào Directus, từng block có thể thay bằng dữ liệu thật nhưng không nên phá vỡ thứ tự logic này.
          </p>
        </div>

        <div class="step-grid">
          {sample.blockOrder.map((block, index) => (
            <article class="step-card">
              <span class="step-index">0{index + 1}</span>
              <h3>{block}</h3>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">SEO & AIO</p>
          <h2>Những tín hiệu SEO, AIO và parseability cần xuất hiện trên template này.</h2>
          <p class="section-intro">
            Phần này tập trung vào những lớp giúp trang vừa đúng search intent, vừa dễ được AI trích xuất, vừa không làm nặng trải nghiệm tải trang.
          </p>
        </div>

        <div class="card-grid card-grid--3">
          {blueprint.answerFirst.map((item) => (
            <article class="content-card">
              <p class="card-eyebrow">Answer-first</p>
              <p>{item}</p>
            </article>
          ))}
          {sample.seoRules.map((rule) => (
            <article class="content-card">
              <p class="card-eyebrow">SEO checkpoint</p>
              <p>{rule}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">HubSpot cluster logic</p>
          <h2>Trang này nằm ở đâu trong topic cluster và nên liên kết như thế nào?</h2>
          <p class="section-intro">
            Đây là lớp kiến trúc giúp template không chỉ đẹp và dễ chuyển đổi, mà còn hoạt động đúng trong hệ hub-spoke của toàn site.
          </p>
        </div>

        <div class="card-grid card-grid--2">
          {blueprint.hubspotInspired.map((item) => (
            <article class="content-card">
              <p class="card-eyebrow">Topic cluster</p>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Schema & tốc độ tải</p>
          <h2>Những lớp dữ liệu có cấu trúc và guardrails hiệu năng nên đi kèm template này.</h2>
        </div>

        <div class="card-grid card-grid--2">
          {blueprint.schema.map((item) => (
            <article class="content-card">
              <p class="card-eyebrow">Schema priority</p>
              <p>{item}</p>
            </article>
          ))}
          {blueprint.performance.map((item) => (
            <article class="content-card">
              <p class="card-eyebrow">Performance guardrail</p>
              <p>{item}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="section-block">
        <div class="section-heading">
          <p class="section-eyebrow">Liên kết nên có</p>
          <h2>Những route chính nên kết nối với template này để phục vụ SEO, trust và conversion.</h2>
        </div>

        <div class="link-grid">
          {sample.internalLinks.map((link) => (
            <a class="link-card" href={link.href}>
              <p class="card-eyebrow">Route liên quan</p>
              <h3>{link.title}</h3>
              <p>{link.body}</p>
              <span>Mở trang</span>
            </a>
          ))}
        </div>
      </section>

      <section class="cta-banner">
        <div>
          <p class="section-eyebrow">CTA chính</p>
          <h2>CTA của template này nên luôn giữ đúng tinh thần rõ, thực dụng và không phô trương.</h2>
          <p>
            CTA chính: <strong>{sample.primaryCta}</strong>. CTA phụ: <strong>{sample.secondaryCta}</strong>. Đây là cặp CTA nên được giữ ổn định khi chuyển template sang page thật.
          </p>
        </div>

        <div class="cta-row">
          <a class="button button--primary" href="/mau-template/">Xem template khác</a>
          <a class="button button--ghost" href={blueprint.productionRoute}>Xem route production gần nhất</a>
        </div>
      </section>
    </main>

    <SiteFooter />
  </div>
</BaseLayout>
