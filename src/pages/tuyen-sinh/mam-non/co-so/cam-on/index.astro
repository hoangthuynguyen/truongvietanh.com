<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="canonical" href={canonicalUrl} />

  <style is:inline>
    :root {
      --n: #0C1E38;
      --b: #1A4D7C;
      --t: #0D9488;
      --td: #0F766E;
      --w: #fff;
      --g1: #F5F7FA;
      --g6: #5F6B7A;
      --g8: #1C2A3A;
      --f: 'Open Sans', system-ui, -apple-system, 'Segoe UI', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: var(--f);
      -webkit-font-smoothing: antialiased;
      font-size: 16px;
      color: var(--g8);
      background: linear-gradient(165deg, #F0FDFA 0%, #CCFBF1 40%, #B2F5EA 100%);
      min-height: 100vh;
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
    }

    .logo-bar {
      text-align: center;
      padding: 24px 16px 0;
    }
    .logo-bar img { height: 56px; opacity: .85; }

    .main {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px 40px;
    }

    .card {
      background: var(--w);
      border-radius: 24px;
      padding: 48px 36px;
      max-width: 560px;
      width: 100%;
      box-shadow: 0 16px 60px rgba(0,0,0,.08);
      text-align: center;
    }

    .icon { font-size: 56px; margin-bottom: 16px; }

    h1 {
      font-family: 'Montserrat', var(--f);
      font-size: 28px;
      font-weight: 800;
      color: var(--n);
      line-height: 1.25;
      margin-bottom: 12px;
    }

    .msg {
      font-size: 18px;
      color: var(--g6);
      line-height: 1.6;
      margin-bottom: 24px;
    }
    .msg strong { color: var(--n); }

    .countdown-wrap {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      background: rgba(13,148,136,.1);
      border: 1px solid rgba(13,148,136,.2);
      color: var(--t);
      padding: 10px 24px;
      border-radius: 20px;
      font-size: 16px;
      font-weight: 700;
      margin-bottom: 28px;
    }

    .contact-box {
      background: var(--g1);
      border-radius: 16px;
      padding: 20px 24px;
      margin-bottom: 32px;
      display: flex;
      flex-direction: column;
      gap: 10px;
      align-items: center;
    }
    .contact-box .label {
      font-size: 14px;
      color: var(--g6);
      font-weight: 600;
    }
    .contact-box .phones {
      display: flex;
      gap: 16px;
      align-items: center;
      flex-wrap: wrap;
      justify-content: center;
    }
    .contact-box a {
      font-size: 20px;
      font-weight: 800;
      color: var(--n);
      text-decoration: none;
      display: flex;
      align-items: center;
      gap: 6px;
    }
    .contact-box a:hover { color: var(--t); }
    .zalo-badge {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      background: #0068FF;
      color: var(--w);
      padding: 4px 12px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 700;
    }

    .divider {
      height: 1px;
      background: #E8ECF0;
      margin: 0 0 28px;
    }

    .cta-label {
      font-size: 14px;
      color: var(--g6);
      margin-bottom: 14px;
      font-weight: 600;
    }
    .ctas { display: flex; flex-direction: column; gap: 12px; }
    .cta {
      display: block;
      width: 100%;
      padding: 16px 20px;
      border-radius: 14px;
      font-size: 17px;
      font-weight: 800;
      text-decoration: none;
      text-align: center;
      transition: all .2s;
      font-family: var(--f);
    }
    .cta-primary {
      background: var(--t);
      color: var(--w);
      box-shadow: 0 4px 16px rgba(13,148,136,.3);
    }
    .cta-primary:hover {
      background: var(--td);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(13,148,136,.35);
    }
    .cta-secondary {
      background: var(--w);
      color: var(--t);
      border: 2px solid var(--t);
    }
    .cta-secondary:hover {
      background: var(--g1);
      transform: translateY(-1px);
    }

    .foot-note {
      font-size: 13px;
      color: var(--g6);
      margin-top: 24px;
      line-height: 1.5;
    }

    @media (max-width: 600px) {
      .card { padding: 36px 20px; }
      h1 { font-size: 24px; }
      .msg { font-size: 16px; }
      .contact-box a { font-size: 18px; }
    }

    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Open+Sans:wght@400;600;700&display=swap&subset=vietnamese');
  </style>

