---
/* Pain Point Solver Landing Page */
const pageTitle = 'Con hay kh횄쨀c khi 횆혩i h찼쨩혥c? 5 sai l찼쨘짠m th횈째찼쨩혶ng g찼쨘쨌p khi ch찼쨩혥n tr횈째찼쨩혶ng m찼쨘짠m non';
const pageDescription = 'T횈째 v찼쨘짜n mi찼쨩혚n ph횄짯 1-1 t찼쨩짬 chuy횄짧n gia t횄짖m l횄쩍 tr찼쨘쨩 em. Kh횄징m ph횄징 5 sai l찼쨘짠m ph찼쨩혮 bi찼쨘쩔n, c횄징ch gi횄쨘p con th횄짯ch nghi nhanh, v횄혻 b횄짯 quy찼쨘쩔t ch찼쨩혥n tr횈째찼쨩혶ng ph횄쨔 h찼쨩짙p.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/mam-non/tu-van';
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta name="twitter:card" content="summary_large_image" />

  <style is:inline>
    :root {
      --n: #0C1E38;
      --b: #E11D48;
      --o: #FB7185;
      --od: #DC2626;
      --w: #fff;
      --g1: #F5F7FA;
      --g2: #DFE3E8;
      --g6: #5F6B7A;
      --g8: #1C2A3A;
      --gn: #1AAB6E;
      --f: 'Open Sans', system-ui, -apple-system, 'Segoe UI', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: var(--f);
      -webkit-font-smoothing: antialiased;
      font-size: 16px;
      color: var(--w);
      background: linear-gradient(165deg, #1C0610 0%, #2D0F1A 40%, #4A1435 100%);
      min-height: 100vh;
      min-height: 100dvh;
    }

    /* Logo */
    .logo-bar {
      text-align: center;
      padding: 20px 12px 0;
    }
    .logo-bar img {
      height: 64px;
      opacity: .9;
      loading: lazy;
    }

    /* Layout */
    .wrap {
      display: flex;
      max-width: 1100px;
      margin: 0 auto;
      padding: 20px 16px 32px;
      gap: 44px;
      align-items: center;
      min-height: calc(100vh - 84px);
      min-height: calc(100dvh - 84px);
    }
    .L { flex: 1; }
    .R { width: 480px; flex-shrink: 0; }

    /* Badge */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 5px;
      background: rgba(251,113,133,.2);
      border: 1px solid rgba(251,113,133,.35);
      color: var(--o);
      padding: 6px 16px;
      border-radius: 16px;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .badge .dot {
      width: 6px;
      height: 6px;
      background: var(--o);
      border-radius: 50%;
      animation: p 1.5s infinite;
    }
    @keyframes p {
      0%, 100% { opacity: 1; }
      50% { opacity: .3; }
    }

    /* Heading */
    h1 {
      font-family: 'Montserrat', var(--f);
      font-size: clamp(28px, 4.5vw, 38px);
      font-weight: 800;
      line-height: 1.18;
      margin-bottom: 20px;
    }
    h1 em {
      color: var(--o);
      font-style: normal;
    }

    /* Perks list */
    .perks {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 24px;
    }
    .perks li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 16px;
      color: rgba(255,255,255,.85);
    }
    .perks .ic {
      width: 32px;
      height: 32px;
      background: rgba(255,255,255,.08);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
      flex-shrink: 0;
    }

    /* Social proof */
    .proof {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      background: rgba(255,255,255,.06);
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,.08);
      margin-bottom: 16px;
    }
    .proof b {
      font-size: 26px;
      color: var(--o);
      line-height: 1;
    }
    .proof span {
      font-size: 14px;
      color: rgba(255,255,255,.55);
      line-height: 1.3;
    }

    /* Footer contact */
    .foot {
      font-size: 14px;
      color: rgba(255,255,255,.5);
      text-align: center;
    }
    .foot a {
      color: var(--o);
      text-decoration: none;
      font-weight: 600;
    }

    /* FORM CARD */
    .F {
      background: var(--w);
      border-radius: 20px;
      padding: 32px 28px;
      box-shadow: 0 20px 60px rgba(0,0,0,.4);
      color: var(--g8);
    }
    .F h2 {
      font-family: 'Montserrat', var(--f);
      font-size: 24px;
      font-weight: 800;
      color: var(--n);
      text-align: center;
      line-height: 1.25;
      margin-bottom: 4px;
    }
    .F .fd {
      font-size: 16px;
      color: var(--g6);
      text-align: center;
      margin-bottom: 18px;
    }
    .F .fd b { color: var(--b); }

    /* Step dots */
    .sd {
      display: flex;
      justify-content: center;
      gap: 5px;
      margin-bottom: 14px;
    }
    .sd i {
      display: block;
      height: 4px;
      border-radius: 2px;
      background: var(--g2);
      width: 30px;
      transition: .3s;
    }
    .sd i.on { background: var(--b); width: 48px; }
    .sd i.ok { background: var(--gn); }

    /* Form fields */
    .fg { margin-bottom: 14px; }
    .fg label {
      display: block;
      font-size: 14px;
      font-weight: 600;
      color: var(--g8);
      margin-bottom: 4px;
    }
    .fg input {
      width: 100%;
      padding: 14px 14px;
      border: 2px solid var(--g2);
      border-radius: 10px;
      font-size: 16px;
      font-family: var(--f);
      background: var(--g1);
      transition: .15s;
    }
    .fg input:focus {
      outline: 0;
      border-color: var(--b);
      background: var(--w);
      box-shadow: 0 0 0 3px rgba(225,29,72,.12);
    }

    /* Buttons */
    .btn {
      width: 100%;
      padding: 18px 16px;
      border: none;
      border-radius: 11px;
      font-size: 18px;
      font-weight: 800;
      cursor: pointer;
      font-family: var(--f);
      transition: all .2s;
      min-height: 56px;
    }
    .bo {
      background: var(--b);
      color: var(--w);
      box-shadow: 0 4px 16px rgba(225,29,72,.35);
    }
    .bo:hover {
      background: var(--od);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(225,29,72,.4);
    }
    .btn:disabled {
      opacity: .5;
      cursor: default;
      transform: none;
      box-shadow: none;
    }

    /* Form meta */
    .fm {
      text-align: center;
      font-size: 12px;
      color: var(--g6);
      margin-top: 10px;
    }
    .fm a {
      color: var(--b);
      font-weight: 600;
    }
    .fb {
      display: flex;
      justify-content: center;
      gap: 14px;
      margin-top: 8px;
      font-size: 12px;
      color: var(--g6);
    }

    /* Steps */
    .s2, .sok { display: none; }
    .sok {
      text-align: center;
      padding: 16px 0;
    }
    .sok .ck {
      font-size: 40px;
      margin-bottom: 8px;
    }
    .sok h3 {
      font-size: 22px;
      color: var(--n);
      font-weight: 800;
    }
    .sok p {
      font-size: 16px;
      color: var(--g6);
      margin-top: 6px;
      line-height: 1.5;
    }
    .sok a {
      color: var(--b);
      font-weight: 700;
      text-decoration: none;
      font-size: 17px;
    }

    /* Responsive */
    @media (max-width: 800px) {
      .wrap {
        flex-direction: column;
        padding: 16px 12px 24px;
        gap: 24px;
        min-height: auto;
      }
      .L {
        text-align: center;
        align-items: center;
        display: flex;
        flex-direction: column;
      }
      h1 { font-size: 26px; }
      .perks {
        align-items: flex-start;
        max-width: 340px;
      }
      .proof { justify-content: center; }
      .R { width: 100%; max-width: 380px; }
      .F { padding: 26px 20px; }
    }

    /* Google Fonts */
    @import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800&family=Open+Sans:wght@400;600;700&display=swap&subset=vietnamese');
  </style>

  <!-- GTM dataLayer -->
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      'event': 'page_view',
      'page_title': 'T횈째 V찼쨘짜n Mi찼쨩혚n Ph횄짯 - M찼쨘짠m Non',
      'page_url': 'https://truongvietanh.com/tuyen-sinh/mam-non/tu-van',
      'school_level': 'mam-non',
      'funnel_code': 'pain-point-mn'
    });
  </script>
</head>
<body>

  <div class="logo-bar">
    <img src="/images/logo-viet-anh.png" alt="Tr횈째찼쨩혶ng Vi찼쨩혝t Anh" loading="lazy" />
  </div>

  <div class="wrap">
    <div class="L">
      <div class="badge">
        <span class="dot"></span>
        챨혺혪징 T횈째 v찼쨘짜n mi찼쨩혚n ph횄짯 1-1
      </div>
      <h1>
        Con hay kh횄쨀c khi 횆혩i h찼쨩혥c?<br/>
        <em>5 sai l찼쨘짠m th횈째찼쨩혶ng g찼쨘쨌p</em><br/>
        khi ch찼쨩혥n tr횈째찼쨩혶ng m찼쨘짠m non
      </h1>
      <ul class="perks">
        <li><div class="ic">창혵혫</div> 5 sai l찼쨘짠m ph찼쨩혮 bi찼쨘쩔n khi ch찼쨩혥n tr횈째찼쨩혶ng</li>
        <li><div class="ic">창혵혫</div> C횄징ch gi횄쨘p con th횄짯ch nghi nhanh</li>
        <li><div class="ic">창혵혫</div> D찼쨘짜u hi찼쨩혝u tr횈째찼쨩혶ng kh횄쨈ng ph횄쨔 h찼쨩짙p</li>
        <li><div class="ic">창혵혫</div> B횄짯 quy찼쨘쩔t t찼쨩짬 chuy횄짧n gia t횄짖m l횄쩍 tr찼쨘쨩 em</li>
        <li><div class="ic">창혵혫</div> Nh찼쨘짯n t횈째 v찼쨘짜n c횄징 nh횄짖n mi찼쨩혚n ph횄짯</li>
      </ul>
      <div class="proof">
        <b>247</b>
        <span>ph찼쨩짜 huynh 횆혩횄짙 횆혩횈째찼쨩짙c t횈째 v찼쨘짜n</span>
      </div>
      <div class="foot">
        챨혺혫혷 <a href="tel:0916961409">0916 961 409</a> 횂쨌 truongvietanh.com
      </div>
    </div>

    <div class="R">
      <div class="F">
        <!-- Step 1: Email -->
        <div class="s1" id="s1">
          <div class="sd"><i class="on"></i><i></i></div>
          <h2>Nh찼쨘짯n t횈째 v찼쨘짜n mi찼쨩혚n ph횄짯</h2>
          <div class="fd">Chuy횄짧n gia t횄짖m l횄쩍 tr찼쨘쨩 t횈째 v찼쨘짜n <b>1-1</b></div>
          <form id="f1">
            <div class="fg">
              <label>Email c찼쨩짠a ba/m찼쨘쨔</label>
              <input type="email" id="email" placeholder="email@example.com" autocomplete="email" required />
            </div>
            <button type="submit" class="btn bo" id="b1">Nh찼쨘짯n t횈째 v찼쨘짜n mi찼쨩혚n ph횄짯 창혛혪</button>
          </form>
          <div class="fm">챨혺혬혪 B찼쨘짙o m찼쨘짯t 횂쨌 T횈째 v찼쨘짜n mi찼쨩혚n ph횄짯</div>
          <div class="fb">
            <span>창혵혫 Mi찼쨩혚n ph횄짯</span>
            <span>창혵혫 Kh횄쨈ng r횄혻ng bu찼쨩혲c</span>
          </div>
        </div>

        <!-- Step 2: Name + Phone -->
        <div class="s2" id="s2">
          <div class="sd"><i class="ok"></i><i class="on"></i></div>
          <h2>Th횄짧m 1 b횈째찼쨩혴c 창혛혪 nh찼쨘짯n t횈째 v찼쨘짜n!</h2>
          <div class="fd">Chuy횄짧n gia s찼쨘쩍 g찼쨩혥i <b>trong 2 gi찼쨩혶</b></div>
          <form id="f2">
            <div class="fg">
              <label>H찼쨩혥 t횄짧n ba/m찼쨘쨔</label>
              <input type="text" id="nm" placeholder="Nguy찼쨩혚n V횆혘n A" required />
            </div>
            <div class="fg">
              <label>S찼쨩혩 횆혩i찼쨩혝n tho찼쨘징i (Zalo)</label>
              <input type="tel" id="ph" placeholder="0912 345 678" required />
            </div>
            <button type="submit" class="btn bo" id="b2">X횄징c nh찼쨘짯n t횈째 v찼쨘짜n 창혛혪</button>
          </form>
          <div class="fm"><a href="#" id="sk">B찼쨩혧 qua 창혛혪</a></div>
        </div>

        <!-- Success -->
        <div class="sok" id="sok">
          <div class="ck">챨혺혦혟</div>
          <h3>횆혨횆혘ng k횄쩍 th횄혻nh c횄쨈ng!</h3>
          <p>Chuy횄짧n gia t횄짖m l횄쩍 s찼쨘쩍 g찼쨩혥i trong 2 gi찼쨩혶<br/>챨혺혫혷 <a href="tel:0916961409">0916 961 409</a></p>
        </div>
      </div>
    </div>
  </div>

  <script is:inline>
    const WEBHOOK = 'https://hook.us2.make.com/2xnm31idzv2otvu5ump548nea04';
    const $ = s => document.getElementById(s);

    $('f1').onsubmit = async e => {
      e.preventDefault();
      const b = $('b1'), v = $('email').value.trim();
      if (!v) return;
      b.disabled = 1;
      b.textContent = '횆혨ang g찼쨩짯i...';
      try {
        await fetch(WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            step: 'partial_capture',
            email: v,
            source: 'pain_point_mn',
            page: window.location.href,
            utm_source: new URLSearchParams(location.search).get('utm_source') || '',
            utm_medium: new URLSearchParams(location.search).get('utm_medium') || '',
            utm_campaign: new URLSearchParams(location.search).get('utm_campaign') || '',
            timestamp: new Date().toISOString()
          })
        });
      } catch (err) {
        console.error('[LeadForm] Step 1 error:', err);
      }
      $('s1').style.display = 'none';
      $('s2').style.display = 'block';
      window.dataLayer?.push({ event: 'lead_s1', variant: 'pain_point', email: v });
    };

    $('f2').onsubmit = async e => {
      e.preventDefault();
      $('b2').disabled = 1;
      try {
        await fetch(WEBHOOK, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            step: 'full_submit',
            email: $('email').value.trim(),
            fullName: $('nm').value.trim(),
            phone: $('ph').value.trim(),
            source: 'pain_point_mn',
            page: window.location.href,
            timestamp: new Date().toISOString()
          })
        });
      } catch (err) {
        console.error('[LeadForm] Step 2 error:', err);
      }
      ok();
      window.dataLayer?.push({ event: 'lead_done', variant: 'pain_point' });
    };

    $('sk').onclick = e => { e.preventDefault(); ok(); };

    function ok() {
      const name = $('nm')?.value?.trim() || '';
      const email = $('email')?.value?.trim() || '';
      window.location.href = '/tuyen-sinh/mam-non/tu-van/cam-on?name=' + encodeURIComponent(name) + '&email=' + encodeURIComponent(email);
    }
  </script>
</body>
</html>
