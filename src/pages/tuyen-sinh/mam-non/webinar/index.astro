      padding: 12px 16px;
      background: rgba(255,255,255,.06);
      border-radius: 10px;
      border: 1px solid rgba(255,255,255,.08);
      margin-bottom: 16px;
    }
    .proof b {
      font-size: 26px;
      color: var(--o);
      line-height: 1;
    }
    .proof span {
      font-size: 14px;
      color: rgba(255,255,255,.55);
      line-height: 1.3;
    }

