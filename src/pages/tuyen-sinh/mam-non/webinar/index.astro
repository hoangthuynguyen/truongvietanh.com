      font-size: 24px;
      font-weight: 800;
      color: var(--n);
      text-align: center;
      line-height: 1.25;
      margin-bottom: 4px;
    }
    .F .fd {
      font-size: 16px;
      color: var(--g6);
      text-align: center;
      margin-bottom: 18px;
    }
    .F .fd b { color: var(--b); }

    /* Step dots */
    .sd {
      display: flex;
      justify-content: center;
      gap: 5px;
      margin-bottom: 14px;
    }
    .sd i {
      display: block;
      height: 4px;
      border-radius: 2px;
      background: var(--g2);
      width: 30px;
      transition: .3s;
    }
    .sd i.on { background: var(--b); width: 48px; }
    .sd i.ok { background: var(--gn); }

