      }
      .L {
        text-align: center;
        align-items: center;
        display: flex;
        flex-direction: column;
      }
      h1 { font-size: 26px; }
      .perks {
        align-items: flex-start;
        max-width: 340px;
      }
      .proof { justify-content: center; }
      .R { width: 100%; max-width: 380px; }
      .F { padding: 26px 20px; }
