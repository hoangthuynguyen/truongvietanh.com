      padding: 20px 12px 0;
    }
    .logo-bar img {
      height: 64px;
      opacity: .9;
      loading: lazy;
    }

    /* Layout */
    .wrap {
      display: flex;
      max-width: 1100px;
      margin: 0 auto;
      padding: 20px 16px 32px;
      gap: 44px;
      align-items: center;
      min-height: calc(100vh - 84px);
      min-height: calc(100dvh - 84px);
    }
    .L { flex: 1; }
    .R { width: 480px; flex-shrink: 0; }

