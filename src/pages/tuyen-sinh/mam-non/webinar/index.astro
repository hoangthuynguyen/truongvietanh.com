      border-radius: 10px;
      font-size: 16px;
      font-family: var(--f);
      background: var(--g1);
      transition: .15s;
    }
    .fg input:focus, .fg select:focus {
      outline: 0;
      border-color: var(--b);
      background: var(--w);
      box-shadow: 0 0 0 3px rgba(124,58,237,.12);
    }

    /* Buttons */
    .btn {
      width: 100%;
      padding: 18px 16px;
      border: none;
      border-radius: 11px;
      font-size: 18px;
      font-weight: 800;
      cursor: pointer;
      font-family: var(--f);
      transition: all .2s;
      min-height: 56px;
    }
    .bo {
      background: var(--b);
      color: var(--w);
      box-shadow: 0 4px 16px rgba(124,58,237,.35);
    }
    .bo:hover {
      background: var(--od);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(124,58,237,.4);
    }
    .btn:disabled {
      opacity: .5;
      cursor: default;
      transform: none;
      box-shadow: none;
    }

    /* Form meta */
    .fm {
      text-align: center;
      font-size: 12px;
      color: var(--g6);
      margin-top: 10px;
