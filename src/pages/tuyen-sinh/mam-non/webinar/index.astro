      color: var(--o);
      padding: 6px 16px;
      border-radius: 16px;
      font-size: 13px;
      font-weight: 700;
      margin-bottom: 16px;
    }
    .badge .dot {
      width: 6px;
      height: 6px;
      background: var(--o);
      border-radius: 50%;
      animation: p 1.5s infinite;
    }
    @keyframes p {
      0%, 100% { opacity: 1; }
      50% { opacity: .3; }
    }

    /* Heading */
    h1 {
      font-family: 'Montserrat', var(--f);
      font-size: clamp(28px, 4.5vw, 38px);
      font-weight: 800;
      line-height: 1.18;
      margin-bottom: 20px;
    }
    h1 em {
      color: var(--o);
      font-style: normal;
    }

    /* Perks list */
    .perks {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 24px;
    }
    .perks li {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 16px;
      color: rgba(255,255,255,.85);
    }
    .perks .ic {
      width: 32px;
      height: 32px;
      background: rgba(255,255,255,.08);
      border-radius: 8px;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 16px;
