---
import LeadFormTwoStepEmailFirst from '../../../../components/LeadFormTwoStepEmailFirst.astro';

const pageTitle = 'Chuyển Cấp Lên THCS – Nỗi Lo Dậy Thì & Giải Pháp An Toàn';
const pageDescription = 'Giải pháp cho phụ huynh lo lắng về chuyển cấp lên THCS và giai đoạn dậy thì của con.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/thcs/chuyen-cap';
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="keywords" content="chuyển cấp THCS, dậy thì, trường Việt Anh, lớp 6" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <style is:inline>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600&display=swap&subset=vietnamese');</style>

  <style is:inline>
    :root{--b:#1F4E79;--o:#E8792B;--w:#fff;--f:'Open Sans',system-ui,sans-serif}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:var(--f);-webkit-font-smoothing:antialiased;color:#1C2A3A;min-height:100vh;display:flex;flex-direction:column;background:linear-gradient(135deg,#FEF2F2,#fff,#F8FAFC);color:#1C2A3A}
    .wrap{flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:48px 20px;text-align:center}
    .badge{display:inline-flex;padding:10px 24px;border-radius:24px;font-size:.875rem;font-weight:600;margin-bottom:32px;background:#FEE2E2;color:#DC2626}
    h1{font-family:'Montserrat',sans-serif;font-size:clamp(1.75rem,5vw,2.25rem);font-weight:800;line-height:1.15;margin-bottom:24px}
    h1 .accent{color:var(--o)}
    .subtitle{font-size:1.1rem;line-height:1.6;margin-bottom:40px;max-width:360px;margin-left:auto;margin-right:auto;opacity:.9}
    .form-wrap{width:100%;max-width:380px;margin:0 auto;background:#fff;border-radius:24px;padding:24px;box-shadow:0 8px 32px rgba(0,0,0,.08)}
    .trust-row{display:flex;flex-wrap:wrap;justify-content:center;gap:16px 24px;margin-top:32px;font-size:.75rem;opacity:.8}
    .trust-row div::before{content:'✓ ';color:#22C55E}
    .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:40px;max-width:380px;margin-left:auto;margin-right:auto}
    .stat-box{background:rgba(0,0,0,.04);border-radius:16px;padding:16px 8px;font-size:.875rem;color:#555}
    .footer-bar{text-align:center;padding:24px;font-size:.75rem;opacity:.5}
    @media(max-width:480px){.wrap{padding:32px 16px}h1{font-size:1.5rem}.subtitle{font-size:1rem}.trust-row{font-size:.7rem}}
  </style>

  <script is:inline>
    window.dataLayer=window.dataLayer||[];
    window.dataLayer.push({event:'page_view',page_title:'Chuyển Cấp Lên THCS – Nỗi Lo Dậy Thì & Giải Pháp An Toàn',school_level:'thcs',funnel_code:'pain-point-thcs'});
  </script>
</head>
<body>
  <div class="wrap">
    <div class="badge">NỖI LO LỚN NHẤT CỦA PHỤ HUYNH LỚP 5</div>
    <h1>Con sắp lên lớp 6 nhưng Ba/Mẹ lo lắng chuyển cấp &amp; dậy thì?<br><span style="color:#DC2626">Giải pháp đồng hành an toàn cho con</span></h1>
    <p class="subtitle">Đừng để con đối mặt với giai đoạn khó khăn nhất một mình. Có một môi trường hiểu tâm lý tuổi dậy thì và đồng hành cùng con.</p>
    <div class="form-wrap">
      <LeadFormTwoStepEmailFirst
        formId="squeeze-pain-point-thcs"
        funnelCode="pain-point-thcs"
        schoolLevel="thcs"
        submitText="Đăng ký ngay"
        successMessage="Cảm ơn! Tư vấn viên sẽ liên hệ trong 5 phút."
      />
    </div>
    <div class="trust-row">
      <div>Tâm lý học đường chuyên biệt</div>
      <div>Giáo viên chủ nhiệm sát sao</div>
      <div>Chương trình kỹ năng sống</div>
    </div>
  </div>
  <div class="footer-bar">Bảo mật thông tin &bull; Tư vấn viên sẽ liên hệ trong 5 phút</div>

</body>
</html>
