---
import SqueezePageLayout from '../../../layouts/SqueezePageLayout.astro';
import LeadFormTwoStepEmailFirst from '../../../components/LeadFormTwoStepEmailFirst.astro';
import USPGrid from '../../../components/USPGrid.astro';
import TrustMetrics from '../../../components/TrustMetrics.astro';
import FAQSection from '../../../components/FAQSection.astro';

const pageTitle = 'Tuyển Sinh THCS - Trường Liên Cấp Việt Anh';
const pageDescription = '95% học sinh Việt Anh vào TOP trường THPT — Bí quyết nằm ở 4 năm THCS. Chương trình song ngữ chuyên sâu, định hướng THPT, IELTS, Coding & AI từ lớp 6.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/thcs';

const uspItems = [
  { icon: '🎯', text: '95% học sinh vào TOP THPT — con bạn sẽ là 1 trong số đó' },
  { icon: '📚', text: 'Song ngữ chuyên sâu: IELTS 5.5-6.5 + Bộ GD&ĐT mạnh mẽ' },
  { icon: '🔬', text: 'STEM nâng cao: Robotics, Coding, AI Lab — không phải "xưng tụng", mà thực hành' },
  { icon: '🌐', text: 'Định hướng THPT ngay từ lớp 6 — Ba/Mẹ không cần "đoán mò" năm lớp 10' },
  { icon: '✈️', text: 'Trao đổi quốc tế: Học sinh được làm Đại sứ, thăm trường đối tác nước ngoài' },
  { icon: '🏆', text: 'Kỹ năng lãnh đạo: Debate, Thuyết trình, MUN — chuẩn bị hành trang THPT top' }
];

const metrics = [
  { number: '15+', label: 'Năm chứng minh chất lượng' },
  { number: '400+', label: 'Học sinh đã trải qua THCS' },
  { number: '95%', label: 'Vào THPT top (Trần Đại Nghĩa, RSHQ...)' },
  { number: '3', label: 'Cơ sở tiêu chuẩn tại TPHCM' }
];

const faqItems = [
  { question: '95% vào THPT top là thật hay chỉ là quảng cáo?', answer: 'Thật. Năm 2025: 38/40 em Việt Anh vào THPT top (Trần Đại Nghĩa, RSHQ, Lê Quý Đôn...). Lý do: (1) Nền tảng tiếng Anh từ Tiểu Học, (2) Tư duy & kỹ năng rèn từ THCS, (3) Lớp nhỏ nên mỗi em được "nhìn thấy" & định hướng riêng.' },
  { question: 'Con tôi không tài Toán — có vào THPT top được không?', answer: 'Được, miễn là em có (1) Tiếng Anh tốt (IELTS 5.0+), (2) Tư duy logic tốt, (3) Kỹ năng thuyết trình/giao tiếp. THPT top không chỉ cần "điểm" mà cần "con người".' },
  { question: 'IELTS từ lớp 6 — con có học kịp được không?', answer: 'Không sợ. Lớp 6-7: Tiếng Anh tích hợp trong Bộ môn. Lớp 8-9: Bắt đầu luyện IELTS chính thức. Mục tiêu: lớp 9 tháng 4, em thi IELTS để có chứng chỉ khi vào THPT.' },
  { question: 'Coding & AI từ THCS — liệu có sơ cơ?', answer: 'Không. Lớp 6-7: Robotics cơ bản. Lớp 8-9: Python, cuộc thi Coding Quốc gia, Dự án AI. Sau THCS, em tự tin chọn ngành Kỹ Thuật/CNTT/Khoa Học.' },
  { question: 'Nhận hồ sơ đến tháng mấy?', answer: 'Tuyển sinh THCS 2026-2027: Nhận hồ sơ từ tháng 3-5/2026, tuyển ~100 học sinh. Ba/Mẹ nên đăng ký tham quan & tư vấn sớm.' }
];
---

<SqueezePageLayout
  title={pageTitle}
  description={pageDescription}
  keywords="THCS, tuyển sinh THCS, trung học cơ sở, trường Việt Anh, song ngữ, IELTS, THPT"
  schoolLevel="thcs"
  funnelCode="tuyen-sinh-thcs"
  canonicalUrl={canonicalUrl}
>
  <div slot="hero">
    <h1 class="hero-h1">95% học sinh Việt Anh vào TOP trường THPT — Bí quyết nằm ở 4 năm THCS</h1>
    <p class="hero-subtitle">Chương trình THCS song ngữ chuyên sâu — Định hướng tương lai từ lớp 6</p>
  </div>

  <div slot="usp"><USPGrid items={uspItems} /></div>
  <div slot="trust"><TrustMetrics metrics={metrics} /></div>

  <div slot="content">
    <div class="content-section">
      <h2>Lớp 6-9 là "Thời kỳ tạo hình" con bạn — Ba/Mẹ có biết?</h2>
      <div class="content-grid">
        <div class="content-card">
          <h3>Quá không chỉ học "ôn tập"</h3>
          <p>THCS Việt Anh là nơi con "tìm ra" mình thích gì, khỏe gì, yếu gì. Mỗi em được "Lộ trình Cá nhân hóa" để tự tin vào THPT.</p>
        </div>
        <div class="content-card">
          <h3>Tiếng Anh là "Chìa khóa" vào THPT top</h3>
          <p>Nhiều trường THPT top chọn em vì Tiếng Anh tốt + Chứng chỉ IELTS. Tại Việt Anh, em học IELTS từ lớp 8, thi chính thức lớp 9.</p>
        </div>
        <div class="content-card">
          <h3>Kỹ năng "Làm Lãnh đạo"</h3>
          <p>Debate, MUN, Thuyết trình, Dự án nhóm. Trường THPT top chọn em vì em "biết cách nói", "biết lắng nghe".</p>
        </div>
        <div class="content-card">
          <h3>STEM nâng cao từ Tiểu Học</h3>
          <p>Robotics lớp 6, Coding Python lớp 7-8, AI Project lớp 9. Em sẽ tham gia cuộc thi Quốc gia, có Portfolio .</p>
        </div>
      </div>
    </div>
    <div class="content-section bonus-section">
      <h2 style="color: #E8792B;">Bonus: Trao đổi quốc tế — Trải nghiệm "Không có ở trường khác"</h2>
      <p style="font-size: 1.05rem; line-height: 1.8; color: #333; text-align: center; max-width: 800px; margin: 0 auto;"><strong>Lớp 8-9</strong>, học sinh được tham gia chương trình trao đổi (2-3 tuần) tại trường đối tác nước ngoài (Mỹ, Anh, Úc).</p>
    </div>
  </div>

  <div slot="form">
    <h2 class="form-heading">Nhận hồ sơ từ tháng 3-5/2026 — Số suất hạn chế, đặt chỗ sớm</h2>
    <p class="form-subheading">Hàng năm, 200+ phụ huynh muốn con vào Việt Anh nhưng trường chỉ có khoảng 100 suất.</p>
    <LeadFormTwoStepEmailFirst formId="tuyen-sinh-form" funnelCode="tuyen-sinh-thcs" schoolLevel="thcs" submitText="Đăng ký tư vấn ngay" successMessage="Cảm ơn Ba/Mẹ! Chúng tôi sẽ liên hệ trong 24h để sắp xếp lịch tham quan & tư vấn." />
  </div>

  <div slot="faq"><FAQSection items={faqItems} title="Câu hỏi phổ biến từ phụ huynh" /></div>
</SqueezePageLayout>

<style>
  .hero-h1 { font-family: "Montserrat", sans-serif; font-size: clamp(1.75rem, 5vw, 2.75rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; color: #1F4E79; }
  .hero-subtitle { font-size: clamp(1rem, 3vw, 1.25rem); font-weight: 500; opacity: 0.95; color: #E8792B; }
  .content-section { margin-bottom: 3rem; }
  .content-section h2 { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 2rem; color: #1F4E79; text-align: center; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .content-card { padding: 2rem; background: white; border: 2px solid #e0e0e0; border-radius: 12px; transition: all 0.3s ease; }
  .content-card:hover { border-color: #E8792B; box-shadow: 0 8px 20px rgba(232, 121, 43, 0.15); transform: translateY(-4px); }
  .content-card h3 { font-family: "Montserrat", sans-serif; font-size: 1.25rem; font-weight: 700; color: #E8792B; margin-bottom: 1rem; }
  .content-card p { font-size: 0.95rem; line-height: 1.7; color: #555; }
  .bonus-section { background: linear-gradient(135deg, #FFF8F0 0%, #FFFBF7 100%); padding: 2rem; border-left: 5px solid #E8792B; border-radius: 8px; }
  .form-heading { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: #E8792B; margin-bottom: 0.5rem; }
  .form-subheading { font-size: 1rem; color: #555; margin-bottom: 2rem; font-weight: 500; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .content-card { padding: 1.5rem; } .bonus-section { padding: 1.5rem; } }
</style>
