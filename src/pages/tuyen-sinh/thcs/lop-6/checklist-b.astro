---
const page_variant = 'checklist_lop6_b';
const funnel = 'squeeze_page_lop6';
const school_level = 'thcs';
const grade = 'lop-6';
---

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>9 tiêu chí vàng chọn trường THCS cho con lớp 6 – Phụ huynh thông thái không thể bỏ qua</title>
  <meta name="description" content="Phụ huynh thông thái đang dùng 9 tiêu chí vàng này để chọn trường THCS tốt nhất cho con lớp 6. Tải miễn phí checklist so sánh trường." />
  <meta name="robots" content="index, follow" />
  <meta property="og:title" content="9 tiêu chí vàng chọn trường THCS cho con lớp 6 – Phụ huynh thông thái không thể bỏ qua" />
  <meta property="og:description" content="Phụ huynh thông thái đang dùng 9 tiêu chí vàng này để chọn trường THCS tốt nhất cho con lớp 6. Tải miễn phí checklist so sánh trường." />
  <meta property="og:type" content="website" />
  <meta property="og:url" content="https://truongvietanh.com/tuyen-sinh/thcs/lop-6/checklist-b/" />
  <meta name="theme-color" content="#1F4E79" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500;600;700;800&family=Open+Sans:wght@400;500;600;700&display=swap&subset=vietnamese" rel="stylesheet" />

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Open Sans', sans-serif;
      background: linear-gradient(135deg, #f8fafc 0%, #ffffff 100%);
      min-height: 100vh;
      color: #1f2937;
    }

    .container {
      max-width: 600px;
      margin: 0 auto;
      padding: 20px;
    }

    .header {
      text-align: center;
      margin-bottom: 40px;
      padding-top: 40px;
    }

    .badge {
      display: inline-block;
      background-color: #1F4E79;
      color: white;
      padding: 8px 16px;
      border-radius: 20px;
      font-size: 12px;
      font-weight: 600;
      margin-bottom: 20px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    h1 {
      font-family: 'Montserrat', sans-serif;
      font-size: 28px;
      font-weight: 800;
      color: #1F4E79;
      margin-bottom: 16px;
      line-height: 1.3;
    }

    .subtitle {
      font-size: 16px;
      color: #6b7280;
      line-height: 1.6;
      margin-bottom: 40px;
    }

    #formContainer {
      background: white;
      border-radius: 12px;
      padding: 30px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
      margin-bottom: 30px;
    }

    #step1 {
      display: block;
    }

    #step2 {
      display: none;
    }

    .form-group {
      margin-bottom: 20px;
    }

    label {
      display: block;
      font-weight: 600;
      margin-bottom: 8px;
      font-size: 14px;
      color: #374151;
    }

    input[type="email"],
    input[type="text"],
    input[type="tel"],
    select {
      width: 100%;
      padding: 12px;
      border: 2px solid #e5e7eb;
      border-radius: 6px;
      font-size: 14px;
      font-family: 'Open Sans', sans-serif;
      transition: border-color 0.3s;
    }

    input[type="email"]:focus,
    input[type="text"]:focus,
    input[type="tel"]:focus,
    select:focus {
      outline: none;
      border-color: #1F4E79;
    }

    button {
      width: 100%;
      padding: 14px;
      background-color: #E8792B;
      color: white;
      border: none;
      border-radius: 6px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      font-family: 'Montserrat', sans-serif;
      transition: background-color 0.3s;
    }

    button:hover {
      background-color: #d66a1a;
    }

    button:active {
      transform: scale(0.98);
    }

    .benefits {
      background: white;
      border-radius: 12px;
      padding: 30px;
      margin-bottom: 30px;
      box-shadow: 0 4px 6px rgba(0, 0, 0, 0.07);
    }

    .benefits h3 {
      font-family: 'Montserrat', sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: #1F4E79;
      margin-bottom: 20px;
    }

    .benefit-item {
      display: flex;
      align-items: flex-start;
      margin-bottom: 14px;
      font-size: 14px;
      line-height: 1.5;
    }

    .benefit-item::before {
      content: "✓";
      color: #E8792B;
      font-weight: bold;
      margin-right: 12px;
      min-width: 20px;
    }

    #thankYou {
      display: none;
      text-align: center;
      padding: 40px 20px;
    }

    .thank-you-icon {
      font-size: 60px;
      margin-bottom: 20px;
    }

    .thank-you-message {
      font-family: 'Montserrat', sans-serif;
      font-size: 18px;
      font-weight: 700;
      color: #1F4E79;
      margin-bottom: 12px;
    }

    .thank-you-text {
      font-size: 14px;
      color: #6b7280;
      line-height: 1.6;
    }

    .step-title {
      font-family: 'Montserrat', sans-serif;
      font-size: 16px;
      font-weight: 700;
      color: #1F4E79;
      margin-bottom: 20px;
    }

    @media (max-width: 480px) {
      .container {
        padding: 16px;
      }

      .header {
        padding-top: 24px;
        margin-bottom: 30px;
      }

      h1 {
        font-size: 22px;
      }

      #formContainer {
        padding: 20px;
      }

      .benefits {
        padding: 20px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="badge">Tài liệu miễn phí dành riêng cho phụ huynh lớp 6</div>
      <h1>9 tiêu chí vàng chọn trường THCS cho con lớp 6 – Phụ huynh thông thái không thể bỏ qua</h1>
      <p class="subtitle">Đừng chọn trường chỉ vì 'nghe nói tốt' – Hãy dùng 9 tiêu chí này để quyết định đúng cho con.</p>
    </div>

    <div id="formContainer">
      <div id="step1">
        <div class="step-title">Bước 1: Nhập email của bạn</div>
        <div class="form-group">
          <input type="email" id="emailInput" placeholder="example@email.com" required />
        </div>
        <button id="btnStep1">Tiếp theo →</button>
      </div>

      <div id="step2">
        <div class="step-title">Bước 2: Hoàn thành thông tin</div>
        <div class="form-group">
          <label for="nameInput">Họ tên phụ huynh</label>
          <input type="text" id="nameInput" placeholder="Nhập họ tên của bạn" required />
        </div>
        <div class="form-group">
          <label for="phoneInput">Số điện thoại</label>
          <input type="tel" id="phoneInput" placeholder="0912345678" required />
        </div>
        <div class="form-group">
          <label for="extraSelect">Khu vực sinh sống</label>
          <select id="extraSelect" required>
            <option value="">-- Chọn khu vực --</option>
            <option value="quan-1-3">Quận 1-3</option>
            <option value="quan-4-8">Quận 4-8</option>
            <option value="quan-7-phu-my-hung">Quận 7 – Phú Mỹ Hưng</option>
            <option value="quan-9-thu-duc">Quận 9 – Thủ Đức</option>
            <option value="binh-thanh-go-vap">Bình Thạnh – Gò Vấp</option>
            <option value="khu-vuc-khac">Khu vực khác</option>
          </select>
        </div>
        <button id="btnStep2">Tải checklist miễn phí</button>
      </div>
    </div>

    <div id="thankYou">
      <div class="thank-you-icon">📋</div>
      <div class="thank-you-message">Tải checklist thành công!</div>
      <div class="thank-you-text">Tư vấn viên sẽ liên hệ hỗ trợ bạn trong 5 phút.</div>
    </div>

    <div class="benefits">
      <h3>Bạn sẽ nhận được:</h3>
      <div class="benefit-item">9 tiêu chí quan trọng nhất khi chọn THCS</div>
      <div class="benefit-item">Cách đánh giá chương trình song ngữ & định hướng quốc tế</div>
      <div class="benefit-item">Lộ trình chuẩn bị chuyển cấp từ lớp 6</div>
      <div class="benefit-item">Bảng so sánh nhanh các trường THCS khu vực bạn</div>
    </div>
  </div>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "9 tiêu chí vàng chọn trường THCS là gì?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Đây là 9 tiêu chí vàng giúp phụ huynh lựa chọn trường THCS phù hợp nhất cho con lớp 6, dựa trên kinh nghiệm của hàng nghìn phụ huynh thông thái."
        }
      },
      {
        "@type": "Question",
        "name": "Làm sao biết lựa chọn trường nào là đúng?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bằng cách áp dụng 9 tiêu chí vàng này, bạn không phải dựa vào 'nghe nói' mà có cơ sở cụ thể để quyết định cho con."
        }
      }
    ]
  }
  </script>

  <script>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      'event': 'page_view',
      'page_title': '9 tiêu chí vàng chọn trường THCS lớp 6 - Version B',
      'page_variant': 'checklist_lop6_b',
      'funnel': 'squeeze_page_lop6',
      'schoolLevel': 'thcs',
      'grade': 'lop-6',
      'pageUrl': window.location.href
    });
  </script>

  <script>
    (function(){
      'use strict';
      var W='https://hook.us2.make.com/yrj1l5kbk79eryk1k9olqfier3a2s2ks';
      var V='checklist_lop6_b';
      var P='squeeze_page_lop6';
      var ps=new URLSearchParams(window.location.search);
      var utm={source:ps.get('utm_source')||'',medium:ps.get('utm_medium')||'',campaign:ps.get('utm_campaign')||'',content:ps.get('utm_content')||'',term:ps.get('utm_term')||'',fbclid:ps.get('fbclid')||'',gclid:ps.get('gclid')||'',ttclid:ps.get('ttclid')||''};
      var emailInput=document.getElementById('emailInput');
      var step1=document.getElementById('step1');
      var step2=document.getElementById('step2');
      var formContainer=document.getElementById('formContainer');
      var thankYou=document.getElementById('thankYou');
      var nameInput=document.getElementById('nameInput');
      var phoneInput=document.getElementById('phoneInput');
      var extraSelect=document.getElementById('extraSelect');
      var storedEmail='';
      var phoneRegex=/^(0|\+84)(3[2-9]|5[2689]|7[06-9]|8[1-9]|9[0-9])\d{7}$/;
      function validateEmail(e){return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)}
      function handleStep1(){
        var email=emailInput.value.trim();
        if(!validateEmail(email)){emailInput.style.borderColor='#EF4444';return}
        storedEmail=email;emailInput.style.borderColor='';
        step1.style.display='none';step2.style.display='block';
        window.dataLayer=window.dataLayer||[];
        window.dataLayer.push({event:'partial_email_capture',page_variant:V,funnel:P,email:email});
      }
      function handleStep2Submit(){
        var name=nameInput.value.trim();
        var phone=phoneInput.value.trim().replace(/\s/g,'');
        var extra=extraSelect?extraSelect.value:'';
        var ok=true;
        if(!name){nameInput.style.borderColor='#EF4444';ok=false}else{nameInput.style.borderColor=''}
        if(!phoneRegex.test(phone)){phoneInput.style.borderColor='#EF4444';ok=false}else{phoneInput.style.borderColor=''}
        if(!ok)return;
        var data={email:storedEmail,parent_name:name,phone:phone,school_level:'thcs',grade:'lop-6',funnel_code:P,page_variant:V,extra_field:extra,utm_source:utm.source,utm_medium:utm.medium,utm_campaign:utm.campaign,utm_content:utm.content,utm_term:utm.term,fbclid:utm.fbclid,gclid:utm.gclid,ttclid:utm.ttclid,submitted_at:new Date().toISOString(),page_url:window.location.href};
        window.dataLayer=window.dataLayer||[];
        window.dataLayer.push({event:'generate_lead',page_variant:V,funnel:P,school_level:'thcs',grade:'lop-6'});
        fetch(W,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)}).then(function(){showThankYou()}).catch(function(){showThankYou()});
      }
      function showThankYou(){formContainer.style.display='none';thankYou.style.display='block'}
      document.getElementById('btnStep1').onclick=handleStep1;
      document.getElementById('btnStep2').onclick=handleStep2Submit;
      emailInput.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();handleStep1()}});
    })();
  </script>
</body>
</html>