---
const pageTitle = 'Early Bird 2026 – Giảm ngay 15% học phí THCS + Học bổng chuyển tiếp lớp 9';
const pageDescription = 'Đăng ký ngay hôm nay để giữ mức học phí thấp nhất và ưu tiên lộ trình lớp 6–9. Giảm 15% học phí THCS và nhận học bổng chuyển tiếp lên đến 50 triệu.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/thcs/lop-6/early-bird-a';
---

<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <link rel="canonical" href={canonicalUrl} />

  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:locale" content="vi_VN" />

  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;600&display=swap" rel="stylesheet" />

  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    html, body {
      width: 100%;
      height: 100%;
    }

    body {
      font-family: 'Open Sans', sans-serif;
      background: linear-gradient(135deg, #1F4E79 0%, #0F2A4A 100%);
      color: #1F1F1F;
      padding: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }

    .container {
      width: 100%;
      max-width: 600px;
    }

    .countdown-badge {
      display: inline-block;
      background: #E8792B;
      color: #fff;
      padding: 12px 24px;
      border-radius: 50px;
      font-size: 0.95rem;
      font-weight: 700;
      margin-bottom: 24px;
      text-align: center;
      width: 100%;
      letter-spacing: 0.5px;
    }

    .countdown-timer {
      font-family: 'Montserrat', sans-serif;
      font-size: 1.1rem;
    }

    h1 {
      font-family: 'Montserrat', sans-serif;
      font-size: 2rem;
      font-weight: 800;
      color: #fff;
      margin-bottom: 16px;
      line-height: 1.2;
      letter-spacing: -0.5px;
    }

    .subtitle {
      font-size: 1.05rem;
      color: rgba(255, 255, 255, 0.95);
      margin-bottom: 32px;
      line-height: 1.5;
      font-weight: 500;
    }

    .form-card {
      background: #fff;
      border-radius: 20px;
      padding: 40px 32px;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.3);
      margin-bottom: 32px;
    }

    #formContainer input,
    #formContainer select {
      font-family: 'Open Sans', sans-serif;
      transition: all 0.3s ease;
    }

    #formContainer input:focus,
    #formContainer select:focus {
      outline: none;
      border-color: #E8792B !important;
      box-shadow: 0 0 0 3px rgba(232, 121, 43, 0.1);
    }

    #step1 p,
    #step2 p {
      font-family: 'Montserrat', sans-serif;
    }

    #btnStep1,
    #btnStep2 {
      transition: all 0.3s ease;
      box-shadow: 0 4px 15px rgba(232, 121, 43, 0.3);
      font-family: 'Montserrat', sans-serif;
    }

    #btnStep1:hover,
    #btnStep2:hover {
      background: #D46A1F !important;
      transform: translateY(-2px);
      box-shadow: 0 6px 20px rgba(232, 121, 43, 0.4);
    }

    #btnStep1:active,
    #btnStep2:active {
      transform: translateY(0);
    }

    .trust-row {
      display: flex;
      flex-direction: column;
      gap: 12px;
      margin-bottom: 24px;
    }

    .trust-item {
      font-size: 0.95rem;
      color: rgba(255, 255, 255, 0.9);
      display: flex;
      align-items: center;
      gap: 10px;
      font-weight: 500;
    }

    .trust-item span {
      color: #E8792B;
      font-weight: 700;
    }

    .footer {
      text-align: center;
      color: rgba(255, 255, 255, 0.7);
      font-size: 0.85rem;
      margin-top: 24px;
    }

    .footer a {
      color: #E8792B;
      text-decoration: none;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    #thankYou h3 {
      font-family: 'Montserrat', sans-serif;
      font-weight: 700;
    }

    @media (max-width: 640px) {
      h1 {
        font-size: 1.6rem;
      }

      .form-card {
        padding: 28px 20px;
      }

      .subtitle {
        font-size: 0.95rem;
      }
    }
  </style>

  <script>
    window.dataLayer = window.dataLayer || [];
    window.dataLayer.push({
      event: 'page_view',
      page_title: 'Early Bird A – THCS Lớp 6',
      page_variant: 'early_bird_lop6_a',
      funnel: 'squeeze_page_lop6'
    });
  </script>
</head>

<body>
  <div class="container">
    <div class="countdown-badge">
      ⏳ Chỉ còn <span class="countdown-timer"><span id="countdownHours">72</span>h <span id="countdownMins">00</span>m</span>
    </div>

    <h1>Early Bird 2026 – Giảm ngay 15% học phí THCS + Học bổng chuyển tiếp lớp 9 lên đến 50 triệu, chỉ còn 72 giờ!</h1>

    <p class="subtitle">Đăng ký ngay hôm nay để giữ mức học phí thấp nhất và ưu tiên lộ trình lớp 6–9</p>

    <div class="form-card">
      <div id="formContainer">
        <div id="step1">
          <p style="font-size:.95rem;color:#1F4E79;font-weight:600;margin-bottom:12px">Bước 1: Xác nhận email</p>
          <input id="emailInput" type="email" placeholder="Nhập email của bạn" style="width:100%;padding:14px 16px;border:2px solid #E5E7EB;border-radius:12px;font-size:1rem;margin-bottom:8px;outline:none;transition:border .2s" />
          <label style="display:flex;align-items:start;gap:8px;font-size:.8rem;color:#6B7280;margin-bottom:12px;cursor:pointer">
            <input type="checkbox" checked style="margin-top:2px" />
            Tôi đồng ý nhận thông tin từ Trường Việt Anh
          </label>
          <button id="btnStep1" type="button" style="width:100%;padding:16px;background:#E8792B;color:#fff;border:none;border-radius:12px;font-size:1.1rem;font-weight:700;cursor:pointer">Tiếp tục →</button>
        </div>
        <div id="step2" style="display:none">
          <p style="font-size:.95rem;color:#1F4E79;font-weight:600;margin-bottom:12px">Bước 2: Thông tin của bạn</p>
          <input id="nameInput" type="text" placeholder="Họ và tên phụ huynh" style="width:100%;padding:14px 16px;border:2px solid #E5E7EB;border-radius:12px;font-size:1rem;margin-bottom:10px;outline:none" />
          <input id="phoneInput" type="tel" placeholder="Số điện thoại / Zalo" style="width:100%;padding:14px 16px;border:2px solid #E5E7EB;border-radius:12px;font-size:1rem;margin-bottom:10px;outline:none" />
          <select id="extraSelect" style="width:100%;padding:14px 16px;border:2px solid #E5E7EB;border-radius:12px;font-size:1rem;margin-bottom:12px;outline:none;background:#fff;color:#374151">
            <option value="">Chọn cơ sở quan tâm</option>
            <option value="co-so-1-quan-3">Cơ sở 1 – Quận 3</option>
            <option value="co-so-2-quan-7">Cơ sở 2 – Quận 7</option>
            <option value="co-so-3-thu-duc">Cơ sở 3 – Thủ Đức</option>
          </select>
          <button id="btnStep2" type="button" style="width:100%;padding:16px;background:#E8792B;color:#fff;border:none;border-radius:12px;font-size:1.1rem;font-weight:700;cursor:pointer">Đăng ký nhận ưu đãi</button>
        </div>
      </div>
      <div id="thankYou" style="display:none;text-align:center;padding:32px 16px">
        <div style="font-size:3rem;margin-bottom:16px">🎉</div>
        <h3 style="color:#1F4E79;font-size:1.3rem;margin-bottom:8px">Đăng ký thành công!</h3>
        <p style="color:#6B7280;font-size:.95rem">Cảm ơn bạn! Tư vấn viên sẽ liên hệ trong 5 phút.</p>
      </div>
    </div>

    <div class="trust-row">
      <div class="trust-item">
        <span>✓</span> Ưu tiên chọn lớp song ngữ
      </div>
      <div class="trust-item">
        <span>✓</span> Học bổng chuyển tiếp THPT
      </div>
      <div class="trust-item">
        <span>✓</span> Đã có 127 phụ huynh đăng ký
      </div>
    </div>

    <div class="footer">
      <p>© 2026 Trường Liên Cấp Việt Anh. Bảo mật thông tin <a href="#">tại đây</a></p>
    </div>
  </div>

  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "EducationalOrganization",
      "name": "Trường Liên Cấp Việt Anh",
      "url": "https://truongvietanh.com",
      "address": {
        "@type": "PostalAddress",
        "addressLocality": "Hồ Chí Minh",
        "addressCountry": "VN"
      }
    }
  </script>

  <script>
    (function(){
      'use strict';
      var W='https://hook.us2.make.com/yrj1l5kbk79eryk1k9olqfier3a2s2ks';
      var V='early_bird_lop6_a';
      var P='squeeze_page_lop6';

      // Collect UTM params
      var ps=new URLSearchParams(window.location.search);
      var utm={source:ps.get('utm_source')||'',medium:ps.get('utm_medium')||'',campaign:ps.get('utm_campaign')||'',content:ps.get('utm_content')||'',term:ps.get('utm_term')||'',fbclid:ps.get('fbclid')||'',gclid:ps.get('gclid')||'',ttclid:ps.get('ttclid')||''};

      var emailInput=document.getElementById('emailInput');
      var step1=document.getElementById('step1');
      var step2=document.getElementById('step2');
      var formContainer=document.getElementById('formContainer');
      var thankYou=document.getElementById('thankYou');
      var nameInput=document.getElementById('nameInput');
      var phoneInput=document.getElementById('phoneInput');
      var extraSelect=document.getElementById('extraSelect');

      var storedEmail='';

      // Vietnamese phone validation
      var phoneRegex=/^(0|\+84)(3[2-9]|5[2689]|7[06-9]|8[1-9]|9[0-9])\d{7}$/;

      function validateEmail(e){return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(e)}

      function handleStep1(){
        var email=emailInput.value.trim();
        if(!validateEmail(email)){emailInput.style.borderColor='#EF4444';return}
        storedEmail=email;
        emailInput.style.borderColor='';
        step1.style.display='none';
        step2.style.display='block';
        window.dataLayer=window.dataLayer||[];
        window.dataLayer.push({event:'partial_email_capture',page_variant:V,funnel:P,email:email});
      }

      function handleStep2Submit(){
        var name=nameInput.value.trim();
        var phone=phoneInput.value.trim().replace(/\s/g,'');
        var extra=extraSelect?extraSelect.value:'';
        var ok=true;
        if(!name){nameInput.style.borderColor='#EF4444';ok=false}else{nameInput.style.borderColor=''}
        if(!phoneRegex.test(phone)){phoneInput.style.borderColor='#EF4444';ok=false}else{phoneInput.style.borderColor=''}
        if(!ok)return;

        var data={email:storedEmail,parent_name:name,phone:phone,school_level:'thcs',grade:'lop-6',funnel_code:P,page_variant:V,extra_field:extra,utm_source:utm.source,utm_medium:utm.medium,utm_campaign:utm.campaign,utm_content:utm.content,utm_term:utm.term,fbclid:utm.fbclid,gclid:utm.gclid,ttclid:utm.ttclid,submitted_at:new Date().toISOString(),page_url:window.location.href};

        window.dataLayer=window.dataLayer||[];
        window.dataLayer.push({event:'generate_lead',page_variant:V,funnel:P,school_level:'thcs',grade:'lop-6'});

        fetch(W,{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(data)})
          .then(function(){showThankYou()})
          .catch(function(){showThankYou()});
      }

      function showThankYou(){
        formContainer.style.display='none';
        thankYou.style.display='block';
      }

      document.getElementById('btnStep1').onclick=handleStep1;
      document.getElementById('btnStep2').onclick=handleStep2Submit;
      emailInput.addEventListener('keydown',function(e){if(e.key==='Enter'){e.preventDefault();handleStep1()}});

      // Countdown timer
      function updateCountdown(){
        var now=new Date();
        var target=new Date(now.getTime()+72*60*60*1000);
        var diff=target-now;
        if(diff>0){
          var hours=Math.floor(diff/(1000*60*60));
          var mins=Math.floor((diff%(1000*60*60))/(1000*60));
          document.getElementById('countdownHours').textContent=hours;
          document.getElementById('countdownMins').textContent=mins<10?'0'+mins:mins;
        }
      }
      updateCountdown();
      setInterval(updateCountdown,60000);
    })();
  </script>
</body>
</html>
