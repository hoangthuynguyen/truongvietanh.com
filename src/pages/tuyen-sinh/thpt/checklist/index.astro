---
import LeadFormTwoStepEmailFirst from '../../../../components/LeadFormTwoStepEmailFirst.astro';

const pageTitle = 'Checklist 9 Tiêu Chí Chọn Tổ Hợp Môn Lớp 10 Theo GDPT Mới';
const pageDescription = 'Tải miễn phí checklist giúp chọn tổ hợp môn lớp 10 tối ưu theo chương trình GDPT mới.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/thpt/checklist';
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="keywords" content="checklist tổ hợp môn, GDPT mới, lớp 10, trường Việt Anh" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <style is:inline>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600&display=swap&subset=vietnamese');</style>

  <style is:inline>
    :root{--b:#1F4E79;--o:#E8792B;--w:#fff;--f:'Open Sans',system-ui,sans-serif}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:var(--f);-webkit-font-smoothing:antialiased;color:#1C2A3A;min-height:100vh;display:flex;flex-direction:column;background:linear-gradient(135deg,#F8FAFC,#fff);color:#1C2A3A}
    .wrap{flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:48px 20px;text-align:center}
    .badge{display:inline-flex;padding:10px 24px;border-radius:24px;font-size:.875rem;font-weight:600;margin-bottom:32px;background:#1F4E79;color:#fff}
    h1{font-family:'Montserrat',sans-serif;font-size:clamp(1.75rem,5vw,2.25rem);font-weight:800;line-height:1.15;margin-bottom:24px}
    h1 .accent{color:var(--o)}
    .subtitle{font-size:1.1rem;line-height:1.6;margin-bottom:40px;max-width:360px;margin-left:auto;margin-right:auto;opacity:.9}
    .form-wrap{width:100%;max-width:380px;margin:0 auto;}
    .trust-row{display:flex;flex-wrap:wrap;justify-content:center;gap:16px 24px;margin-top:32px;font-size:.75rem;opacity:.8}
    .trust-row div::before{content:'✓ ';color:#22C55E}
    .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:40px;max-width:380px;margin-left:auto;margin-right:auto}
    .stat-box{background:rgba(0,0,0,.04);border-radius:16px;padding:16px 8px;font-size:.875rem;color:#555}
    .footer-bar{text-align:center;padding:24px;font-size:.75rem;opacity:.5}
    @media(max-width:480px){.wrap{padding:32px 16px}h1{font-size:1.5rem}.subtitle{font-size:1rem}.trust-row{font-size:.7rem}}
  </style>

  <script is:inline>
    window.dataLayer=window.dataLayer||[];
    window.dataLayer.push({event:'page_view',page_title:'Checklist 9 Tiêu Chí Chọn Tổ Hợp Môn Lớp 10 Theo GDPT Mới',school_level:'thpt',funnel_code:'checklist-lop10'});
  </script>
</head>
<body>
  <div class="wrap">
    <div class="badge">TÀI LIỆU MIỄN PHÍ DÀNH CHO PHỤ HUYNH LỚP 10</div>
    <h1>Checklist 9 tiêu chí chọn tổ hợp môn lớp 10<br><span class="accent">theo chương trình GDPT mới – Không còn lạc hướng</span></h1>
    <p class="subtitle">Giúp cha mẹ tự tin chọn tổ hợp môn phù hợp với năng lực và định hướng tương lai của con (thi Đại học hay du học).</p>
    <div class="form-wrap">
      <LeadFormTwoStepEmailFirst
        formId="squeeze-checklist-lop10"
        funnelCode="checklist-lop10"
        schoolLevel="thpt"
        submitText="Đăng ký ngay"
        successMessage="Cảm ơn! Tư vấn viên sẽ liên hệ trong 5 phút."
      />
    </div>
    <div class="trust-row">
      <div>9 tiêu chí chọn tổ hợp môn tối ưu</div>
      <div>Bảng so sánh các tổ hợp phổ biến</div>
      <div>Lộ trình 3 năm thi ĐH & du học</div>
    </div>
  </div>
  <div class="footer-bar">Bảo mật thông tin &bull; Tư vấn viên sẽ liên hệ trong 5 phút</div>

</body>
</html>
