---
import LeadFormTwoStepEmailFirst from '../../../../components/LeadFormTwoStepEmailFirst.astro';

const pageTitle = 'Early Bird Lớp 10 2026 – Giảm 15% + Học Bổng 70 Triệu | Trường Việt Anh';
const pageDescription = 'Đăng ký sớm lớp 10 THPT 2026 tại Trường Việt Anh. Giảm 15% học phí và học bổng chuyển tiếp lên đến 70 triệu.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/thpt/dang-ky-som';
---

<!doctype html>
<html lang="vi">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{pageTitle}</title>
  <meta name="description" content={pageDescription} />
  <meta name="keywords" content="early bird lớp 10, đăng ký sớm THPT, trường Việt Anh, học bổng lớp 10" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonicalUrl} />
  <meta property="og:title" content={pageTitle} />
  <meta property="og:description" content={pageDescription} />
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalUrl} />
  <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <style is:inline>@import url('https://fonts.googleapis.com/css2?family=Montserrat:wght@600;700;800&family=Open+Sans:wght@400;500;600&display=swap&subset=vietnamese');</style>

  <style is:inline>
    :root{--b:#1F4E79;--o:#E8792B;--w:#fff;--f:'Open Sans',system-ui,sans-serif}
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:var(--f);-webkit-font-smoothing:antialiased;color:#1C2A3A;min-height:100vh;display:flex;flex-direction:column;background:linear-gradient(135deg,#1F4E79 0%,#0F2A4A 100%);color:#fff}
    .wrap{flex:1;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:48px 20px;text-align:center}
    .badge{display:inline-flex;padding:10px 24px;border-radius:24px;font-size:.875rem;font-weight:600;margin-bottom:32px;background:#E8792B;color:#fff}
    h1{font-family:'Montserrat',sans-serif;font-size:clamp(1.75rem,5vw,2.25rem);font-weight:800;line-height:1.15;margin-bottom:24px}
    h1 .accent{color:var(--o)}
    .subtitle{font-size:1.1rem;line-height:1.6;margin-bottom:40px;max-width:360px;margin-left:auto;margin-right:auto;opacity:.9}
    .form-wrap{width:100%;max-width:380px;margin:0 auto;background:#fff;border-radius:24px;padding:24px;box-shadow:0 12px 40px rgba(0,0,0,.15)}
    .trust-row{display:flex;flex-wrap:wrap;justify-content:center;gap:16px 24px;margin-top:32px;font-size:.75rem;opacity:.8}
    .trust-row div::before{content:'✓ ';color:#22C55E}
    .stats-row{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-top:40px;max-width:380px;margin-left:auto;margin-right:auto}
    .stat-box{background:rgba(0,0,0,.04);border-radius:16px;padding:16px 8px;font-size:.875rem;color:#555}
    .footer-bar{text-align:center;padding:24px;font-size:.75rem;opacity:.5}
    @media(max-width:480px){.wrap{padding:32px 16px}h1{font-size:1.5rem}.subtitle{font-size:1rem}.trust-row{font-size:.7rem}}
  </style>

  <script is:inline>
    window.dataLayer=window.dataLayer||[];
    window.dataLayer.push({event:'page_view',page_title:'Early Bird Lớp 10 2026 – Giảm 15% + Học Bổng 70 Triệu | Trường Việt Anh',school_level:'thpt',funnel_code:'early-bird-lop10'});
  </script>
</head>
<body>
  <div class="wrap">
    <div class="badge">⏰ Ưu đãi chỉ còn <span id="countdown" style="font-family:Montserrat,sans-serif;font-size:1.5rem;font-weight:800;margin:0 4px">72h</span></div>
    <h1>Early Bird 2026 – Giảm ngay 15% học phí lớp 10<br><span class="accent">+ Học bổng chuyển tiếp lên đến 70 triệu</span></h1>
    <p class="subtitle">Đăng ký hôm nay để khóa mức học phí thấp nhất và ưu tiên lộ trình thi Đại học hoặc du học cho con</p>
    <div class="form-wrap">
      <LeadFormTwoStepEmailFirst
        formId="squeeze-early-bird-lop10"
        funnelCode="early-bird-lop10"
        schoolLevel="thpt"
        submitText="Đăng ký ngay"
        successMessage="Cảm ơn! Tư vấn viên sẽ liên hệ trong 5 phút."
      />
    </div>
    <div class="trust-row">
      <div>Ưu tiên chọn tổ hợp môn tối ưu</div>
      <div>Học bổng chuyển tiếp THPT</div>
      <div>Đã có 96 phụ huynh đăng ký đợt này</div>
    </div>
  </div>
  <div class="footer-bar">Bảo mật thông tin &bull; Tư vấn viên sẽ liên hệ trong 5 phút</div>
<script is:inline>
  (function(){var t=72*3600,e=document.getElementById('countdown');if(!e)return;setInterval(function(){t--;var h=Math.floor(t/3600);e.textContent=h+'h'},1e3)})();
</script>
</body>
</html>
