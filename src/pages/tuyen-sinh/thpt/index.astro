---
import SqueezePageLayout from '../../../layouts/SqueezePageLayout.astro';
import LeadFormTwoStepEmailFirst from '../../../components/LeadFormTwoStepEmailFirst.astro';
import USPGrid from '../../../components/USPGrid.astro';
import TrustMetrics from '../../../components/TrustMetrics.astro';
import FAQSection from '../../../components/FAQSection.astro';

const pageTitle = 'Tuyển Sinh THPT - Trường Liên Cấp Việt Anh';
const pageDescription = '90% học sinh Việt Anh đỗ đại học nguyện vọng 1 — 30% du học thành công. IELTS 6.5-7.5, Luyện THPTQG, Liên kết ĐH quốc tế, Lab hiện đại, Kỹ năng thế kỉ 21.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/thpt';

const uspItems = [
  { icon: '🎓', text: '90%+ đỗ ĐH nguyện vọng 1 — Con bạn sẽ là 1 trong số đó' },
  { icon: '🌍', text: '30% du học thành công (Mỹ, Anh, Úc, Canada) — Con có "Hành trang quốc tế"' },
  { icon: '📚', text: 'IELTS 6.5-7.5 khi tốt nghiệp — Không cần "ôn thêm" sau THPT' },
  { icon: '🔬', text: 'THPTQG chuyên sâu: Lớp 10 đã bắt đầu ôn tập chiến lược (không phải "ĐắN dồn cuối"' },
  { icon: '💼', text: 'Tư vấn Đại Học 1-1: Chọn ngành phù hợp, không phải "Ba/Mẹ đoán mò"' },
  { icon: '🏫', text: 'Liên kết ĐH trong & ngoài: Học sinh Việt Anh được Đại Học "nhìn thấy" & ưu tiên' }
];

const metrics = [
  { number: '15+', label: 'Năm hành trình từ Tiểu Học đến THPT' },
  { number: '90%+', label: 'Đỗ ĐH Nguyện Vọng 1 (2025: 36/40 em)' },
  { number: '30%', label: 'Du học nước ngoài thành công (Mỹ, Anh, Úc, Canada)' },
  { number: '3', label: 'Cơ sở tiêu chuẩn tại TPHCM' }
];

const faqItems = [
  { question: 'Tại sao 90%+ vào ĐH NV1 — con tôi có vào được không?', answer: 'Con bạn vào được nếu (1) Hoàn thành 3 năm THPT, (2) Điểm THPTQG 20+, (3) IELTS 5.0+. Không phải "thần đồng" — chỉ cần "chăm chỉ".' },
  { question: 'IELTS 6.5-7.5 — con tôi không giỏi Tiếng Anh, sợ không đạt?', answer: 'Không sợ. IELTS được dạy tích hợp trong Tiếng Anh chính khóa. Hàng năm, >90% em đạt 5.5-6.5 trước tốt nghiệp.' },
  { question: 'Luyện thi THPTQG từ lớp 10 — con có mệt không?', answer: 'Không mệt, vì chúng tôi luyện "chiến lược", không phải "nạp kiến thức". Lớp 12 không cần "ôn từ đầu".' },
  { question: 'Muốn du học Mỹ/Anh/Úc — trường hỗ trợ không?', answer: 'Có. Bộ phận Tư vấn Du Học hỗ trợ chọn trường, viết Essay, Visa. Hàng năm, 30% em chọn du học.' },
  { question: 'THPT Việt Anh chuyên gì?', answer: 'Không chuyên. Nhưng em được chọn "Khối học" ngay từ lớp 10 để "tinh gọn" kiến thức.' },
  { question: 'Nhận hồ sơ THPT từ tháng mấy?', answer: 'Từ tháng 3 hàng năm, tuyển ~60 học sinh lớp 10. Số suất giới hạn. Nên đăng ký tư vấn sớm.' }
];
---

<SqueezePageLayout
  title={pageTitle}
  description={pageDescription}
  keywords="THPT, tuyển sinh THPT, trung học phổ thông, trường Việt Anh, song ngữ, du học, IELTS"
  schoolLevel="thpt"
  funnelCode="tuyen-sinh-thpt"
  canonicalUrl={canonicalUrl}
>
  <div slot="hero">
    <h1 class="hero-h1">90% học sinh Việt Anh đỗ ĐH nguyện vọng 1 — 30% du học thành công</h1>
    <p class="hero-subtitle">Chương trình THPT song ngữ — Chuẩn bị hành trang cho đại học trong nước & quốc tế</p>
  </div>

  <div slot="usp"><USPGrid items={uspItems} /></div>
  <div slot="trust"><TrustMetrics metrics={metrics} /></div>

  <div slot="content">
    <div class="content-section">
      <h2>Lớp 10-12 Không Phải "Ôn Bài Cũ" — Mà là "Xây Hành Trang Tương Lai"</h2>
      <div class="content-grid">
        <div class="content-card">
          <h3>THPTQG từ lớp 10 — Không "Đắn dồn" lớp 12</h3>
          <p>Con bạn đã làm 100+ đề THPTQG. Em sẽ tự tin, không sợ "Lạc đường" lúc thi.</p>
        </div>
        <div class="content-card">
          <h3>IELTS không phải "Công việc thêm"</h3>
          <p>Hàng tuần, em làm IELTS Practice Test. Lớp 11 Tháng 5, em thi IELTS chính thức có Chứng chỉ.</p>
        </div>
        <div class="content-card">
          <h3>Tư vấn Đại Học Cá Nhân 1-1</h3>
          <p>Lớp 11, mỗi em được 1 cuộc tư vấn riêng (Cô + Ba/Mẹ) để chọn ngành thật sự yêu thích.</p>
        </div>
        <div class="content-card">
          <h3>Du Học Thực Tế</h3>
          <p>Hàng năm, 30% em du học. Được hỗ trợ Essay, Hồ sơ, Visa, Liên hệ trường.</p>
        </div>
      </div>
    </div>
    <div class="content-section bonus-section">
      <h2 style="color: #E8792B;">Bonus: Liên kết Đại Học — Học sinh Việt Anh được "Nhìn Thấy"</h2>
      <p style="font-size: 1.05rem; line-height: 1.8; color: #333; text-align: center; max-width: 800px; margin: 0 auto;"><strong>Liên kết với 50+ Đại Học</strong> tại Việt Nam & quốc tế. Học sinh được "Ưu tiên Xét Tuyển".</p>
    </div>
  </div>

  <div slot="form">
    <h2 class="form-heading">Chỉ còn 20 suất cho lớp 10 năm học 2026-2027 — Đặt chỗ sớm</h2>
    <p class="form-subheading">Hàng năm, 300+ phụ huynh quan tâm nhưng trường chỉ nhận 60 em.</p>
    <LeadFormTwoStepEmailFirst formId="tuyen-sinh-form" funnelCode="tuyen-sinh-thpt" schoolLevel="thpt" submitText="Đăng ký tư vấn ngay" successMessage="Cảm ơn Ba/Mẹ! Chúng tôi sẽ liên hệ trong 24h để sắp xếp lịch tham quan & tư vấn chi tiết." />
  </div>

  <div slot="faq"><FAQSection items={faqItems} title="Những câu hỏi Ba/Mẹ hay hỏi" /></div>
</SqueezePageLayout>

<style>
  .hero-h1 { font-family: "Montserrat", sans-serif; font-size: clamp(1.75rem, 5vw, 2.75rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; color: #1F4E79; }
  .hero-subtitle { font-size: clamp(1rem, 3vw, 1.25rem); font-weight: 500; opacity: 0.95; color: #E8792B; }
  .content-section { margin-bottom: 3rem; }
  .content-section h2 { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 2rem; color: #1F4E79; text-align: center; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .content-card { padding: 2rem; background: white; border: 2px solid #e0e0e0; border-radius: 12px; transition: all 0.3s ease; }
  .content-card:hover { border-color: #E8792B; box-shadow: 0 8px 20px rgba(232, 121, 43, 0.15); transform: translateY(-4px); }
  .content-card h3 { font-family: "Montserrat", sans-serif; font-size: 1.25rem; font-weight: 700; color: #E8792B; margin-bottom: 1rem; }
  .content-card p { font-size: 0.95rem; line-height: 1.7; color: #555; }
  .bonus-section { background: linear-gradient(135deg, #FFF8F0 0%, #FFFBF7 100%); padding: 2rem; border-left: 5px solid #E8792B; border-radius: 8px; }
  .form-heading { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: #E8792B; margin-bottom: 0.5rem; }
  .form-subheading { font-size: 1rem; color: #555; margin-bottom: 2rem; font-weight: 500; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .content-card { padding: 1.5rem; } .bonus-section { padding: 1.5rem; } }
</style>
