---
import SqueezePageLayout from '../../../../layouts/SqueezePageLayout.astro';
import LeadFormTwoStepEmailFirst from '../../../../components/LeadFormTwoStepEmailFirst.astro';
import USPGrid from '../../../../components/USPGrid.astro';
import TrustMetrics from '../../../../components/TrustMetrics.astro';
import FAQSection from '../../../../components/FAQSection.astro';

const pageTitle = 'Chương Trình Tiểu Học Song Ngữ – Trường Việt Anh';
const pageDescription = 'Tìm hiểu chương trình Tiểu Học song ngữ chuẩn quốc tế tại Trường Việt Anh: Cambridge, STEM, ngoại khóa phong phú.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/tieu-hoc/chuong-trinh';

const uspItems = [
  { icon: '🌍', text: 'Chương trình song ngữ Anh-Việt chuẩn quốc tế' },
  { icon: '👨‍🏫', text: 'Giáo viên nước ngoài dạy tiếng Anh chuyên sâu' },
  { icon: '🏆', text: 'Học sinh đạt thành tích xuất sắc các kỳ thi' },
  { icon: '🎨', text: 'Phương pháp giảng dạy hiện đại, lấy học sinh làm trung tâm' },
  { icon: '🤝', text: 'Cộng đồng phụ huynh tích cực và gắn kết' },
  { icon: '⚽', text: 'Hơn 20 CLB ngoại khóa: thể thao, nghệ thuật, STEM' }
];

const metrics = [
  { number: '15+', label: 'Năm kinh nghiệm giáo dục' },
  { number: '500+', label: 'Học sinh Tiểu Học' },
  { number: '98%', label: 'Phụ huynh hài lòng' },
  { number: '3', label: 'Cơ sở tại TPHCM' }
];

const faqItems = [
  { question: 'Chương trình có được Bộ GD&ĐT công nhận không?', answer: 'Có, Trường Việt Anh được Sở GD&ĐT TP.HCM cấp phép và chương trình đáp ứng đầy đủ yêu cầu của Bộ GD&ĐT.' },
  { question: 'Tỷ lệ tiếng Anh trong chương trình là bao nhiêu?', answer: 'Khoảng 50% thời lượng học bằng tiếng Anh, bao gồm các môn Toán, Khoa học và Tiếng Anh chuyên sâu.' },
  { question: 'Học sinh có thể chuyển sang trường công lập được không?', answer: 'Hoàn toàn có thể. Chương trình đáp ứng đủ yêu cầu của Bộ GD&ĐT nên học sinh được công nhận kết quả khi chuyển trường.' }
];
---

<SqueezePageLayout
  title={pageTitle}
  description={pageDescription}
  keywords="chương trình tiểu học, song ngữ, Cambridge, STEM, trường Việt Anh"
  schoolLevel="tieu-hoc"
  funnelCode="chuong-trinh-tieu-hoc"
  canonicalUrl={canonicalUrl}
>
  <div slot="hero">
    <h1 class="hero-h1">Chương Trình Tiểu Học Song Ngữ<br/>Chuẩn Quốc Tế Cambridge</h1>
    <p class="hero-subtitle">Nền tảng kiến thức vững chắc + Tiếng Anh thành thạo + Kỹ năng sống toàn diện</p>
  </div>

  <div slot="usp">
    <USPGrid items={uspItems} />
  </div>

  <div slot="trust">
    <TrustMetrics metrics={metrics} />
  </div>

  <div slot="content">
    <div class="content-section">
      <h2>Điểm nổi bật của chương trình</h2>
      <div class="content-grid">
        <div class="content-card">
          <h3>Cambridge + Bộ GD&ĐT</h3>
          <p>Kết hợp hoàn hảo giữa chương trình quốc tế Cambridge và chương trình chuẩn của Bộ GD&ĐT Việt Nam.</p>
        </div>
        <div class="content-card">
          <h3>STEM từ lớp 1</h3>
          <p>Học sinh được tiếp cận tư duy STEM ngay từ lớp 1 với phòng lab hiện đại và dự án thực tế.</p>
        </div>
        <div class="content-card">
          <h3>Tiếng Anh chuyên sâu</h3>
          <p>50% thời lượng học bằng tiếng Anh với giáo viên bản ngữ. Mục tiêu A2-B1 khi kết thúc Tiểu Học.</p>
        </div>
        <div class="content-card">
          <h3>20+ CLB ngoại khóa</h3>
          <p>Bóng đá, bơi lội, piano, robotics, coding, mỹ thuật, nhảy hiện đại... phát triển toàn diện.</p>
        </div>
      </div>
    </div>
  </div>

  <div slot="form">
    <h2 class="form-heading">Nhận thông tin chương trình chi tiết</h2>
    <p class="form-subheading">Để lại email để nhận brochure chương trình Tiểu Học song ngữ</p>
    <LeadFormTwoStepEmailFirst
      formId="tuyen-sinh-form"
      funnelCode="chuong-trinh-tieu-hoc"
      schoolLevel="tieu-hoc"
      submitText="Nhận thông tin"
      successMessage="Brochure chương trình đã gửi qua email! Bộ phận Tuyển sinh sẽ liên hệ hỗ trợ thêm."
    />
  </div>

  <div slot="faq">
    <FAQSection items={faqItems} title="Câu hỏi về Chương trình Tiểu Học" />
  </div>
</SqueezePageLayout>

<style>
  .hero-h1 { font-family: "Montserrat", sans-serif; font-size: clamp(1.75rem, 5vw, 2.75rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
  .hero-subtitle { font-size: clamp(1rem, 3vw, 1.25rem); font-weight: 500; opacity: 0.95; }
  .content-section h2 { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 2rem; color: #1F4E79; text-align: center; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .content-card { padding: 2rem; background: white; border: 1px solid #e0e0e0; border-radius: 12px; transition: all 0.3s ease; }
  .content-card:hover { border-color: #E8792B; box-shadow: 0 8px 20px rgba(232, 121, 43, 0.12); transform: translateY(-4px); }
  .content-card h3 { font-family: "Montserrat", sans-serif; font-size: 1.25rem; font-weight: 700; color: #1F4E79; margin-bottom: 1rem; }
  .content-card p { font-size: 0.95rem; line-height: 1.6; color: #666666; }
  .form-heading { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: #1F4E79; margin-bottom: 0.5rem; }
  .form-subheading { font-size: 1rem; color: #666666; margin-bottom: 2rem; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .content-card { padding: 1.5rem; } }
</style>
