---
import SqueezePageLayout from '../../../../layouts/SqueezePageLayout.astro';
import LeadFormTwoStepEmailFirst from '../../../../components/LeadFormTwoStepEmailFirst.astro';
import USPGrid from '../../../../components/USPGrid.astro';
import TrustMetrics from '../../../../components/TrustMetrics.astro';
import FAQSection from '../../../../components/FAQSection.astro';

const pageTitle = 'Đăng Ký Sớm Tiểu Học 2026 – Ưu Đãi Học Phí | Trường Việt Anh';
const pageDescription = 'Đăng ký sớm chương trình Tiểu Học 2026 tại Trường Việt Anh để nhận ưu đãi học phí và ưu tiên xếp lớp song ngữ.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/tieu-hoc/dang-ky-som';

const uspItems = [
  { icon: '🌍', text: 'Chương trình song ngữ Anh-Việt chuẩn quốc tế' },
  { icon: '👨‍🏫', text: 'Giáo viên nước ngoài dạy tiếng Anh chuyên sâu' },
  { icon: '🏆', text: 'Học sinh đạt thành tích xuất sắc các kỳ thi' },
  { icon: '🎨', text: 'Phương pháp giảng dạy hiện đại, lấy học sinh làm trung tâm' },
  { icon: '🤝', text: 'Cộng đồng phụ huynh tích cực và gắn kết' },
  { icon: '⚽', text: 'Hơn 20 CLB ngoại khóa: thể thao, nghệ thuật, STEM' }
];

const metrics = [
  { number: '15+', label: 'Năm kinh nghiệm giáo dục' },
  { number: '500+', label: 'Học sinh Tiểu Học' },
  { number: '98%', label: 'Phụ huynh hài lòng' },
  { number: '3', label: 'Cơ sở tại TPHCM' }
];

const faqItems = [
  { question: 'Ưu đãi đăng ký sớm bao gồm những gì?', answer: 'Giảm 15% học phí năm đầu, tặng bộ đồ dùng học tập trị giá 3 triệu đồng, ưu tiên chọn lớp song ngữ và đánh giá năng lực miễn phí.' },
  { question: 'Hạn chót đăng ký sớm là khi nào?', answer: 'Chương trình ưu đãi Early Bird áp dụng đến hết ngày 30/06/2026 hoặc khi đủ chỉ tiêu.' },
  { question: 'Con chưa đủ tuổi vào lớp 1, có đăng ký được không?', answer: 'Chương trình dành cho bé đủ 6 tuổi tính đến tháng 9/2026. Ba/Mẹ có thể đăng ký giữ chỗ trước.' }
];
---

<SqueezePageLayout
  title={pageTitle}
  description={pageDescription}
  keywords="đăng ký sớm tiểu học, early bird tiểu học, trường Việt Anh, ưu đãi học phí"
  schoolLevel="tieu-hoc"
  funnelCode="early-bird-tieu-hoc"
  canonicalUrl={canonicalUrl}
>
  <div slot="hero">
    <h1 class="hero-h1">Đăng Ký Sớm Tiểu Học 2026<br/>Ưu Đãi Giảm 15% Học Phí</h1>
    <p class="hero-subtitle">Khóa mức học phí tốt nhất & ưu tiên chọn lớp song ngữ cho con ngay hôm nay</p>
  </div>

  <div slot="usp">
    <USPGrid items={uspItems} />
  </div>

  <div slot="trust">
    <TrustMetrics metrics={metrics} />
  </div>

  <div slot="content">
    <div class="content-section">
      <h2>Tại sao đăng ký sớm Tiểu Học Việt Anh?</h2>
      <div class="content-grid">
        <div class="content-card">
          <h3>Tiết kiệm học phí</h3>
          <p>Giảm 15% học phí năm đầu khi đăng ký trước 30/06/2026. Cam kết không tăng phí suốt 5 năm Tiểu Học.</p>
        </div>
        <div class="content-card">
          <h3>Ưu tiên xếp lớp</h3>
          <p>Được ưu tiên chọn lớp song ngữ chất lượng cao với sĩ số giới hạn chỉ 25 học sinh/lớp.</p>
        </div>
        <div class="content-card">
          <h3>Tặng bộ đồ dùng</h3>
          <p>Nhận trọn bộ đồ dùng học tập, đồng phục và sách giáo khoa cho năm học đầu tiên.</p>
        </div>
        <div class="content-card">
          <h3>Lộ trình cá nhân</h3>
          <p>Đánh giá năng lực đầu vào miễn phí và xây dựng lộ trình học tập phù hợp cho từng bé.</p>
        </div>
      </div>
    </div>
  </div>

  <div slot="form">
    <h2 class="form-heading">Đăng ký sớm – Nhận ưu đãi ngay</h2>
    <p class="form-subheading">Chỉ cần để lại email để giữ chỗ và nhận thông tin ưu đãi chi tiết</p>
    <LeadFormTwoStepEmailFirst
      formId="tuyen-sinh-form"
      funnelCode="early-bird-tieu-hoc"
      schoolLevel="tieu-hoc"
      submitText="Giữ chỗ ngay"
      successMessage="Cảm ơn Ba/Mẹ! Bộ phận Tuyển sinh sẽ gửi thông tin ưu đãi qua email trong 24h."
    />
  </div>

  <div slot="faq">
    <FAQSection items={faqItems} title="Câu hỏi về Đăng ký sớm Tiểu Học" />
  </div>
</SqueezePageLayout>

<style>
  .hero-h1 { font-family: "Montserrat", sans-serif; font-size: clamp(1.75rem, 5vw, 2.75rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
  .hero-subtitle { font-size: clamp(1rem, 3vw, 1.25rem); font-weight: 500; opacity: 0.95; }
  .content-section h2 { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 2rem; color: #1F4E79; text-align: center; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .content-card { padding: 2rem; background: white; border: 1px solid #e0e0e0; border-radius: 12px; transition: all 0.3s ease; }
  .content-card:hover { border-color: #E8792B; box-shadow: 0 8px 20px rgba(232, 121, 43, 0.12); transform: translateY(-4px); }
  .content-card h3 { font-family: "Montserrat", sans-serif; font-size: 1.25rem; font-weight: 700; color: #1F4E79; margin-bottom: 1rem; }
  .content-card p { font-size: 0.95rem; line-height: 1.6; color: #666666; }
  .form-heading { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: #1F4E79; margin-bottom: 0.5rem; }
  .form-subheading { font-size: 1rem; color: #666666; margin-bottom: 2rem; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .content-card { padding: 1.5rem; } }
</style>
