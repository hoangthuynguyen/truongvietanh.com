---
import SqueezePageLayout from '../../../../layouts/SqueezePageLayout.astro';
import LeadFormTwoStepEmailFirst from '../../../../components/LeadFormTwoStepEmailFirst.astro';
import USPGrid from '../../../../components/USPGrid.astro';
import TrustMetrics from '../../../../components/TrustMetrics.astro';
import FAQSection from '../../../../components/FAQSection.astro';

const pageTitle = 'So Sánh Trường Tiểu Học – Trường Việt Anh vs Các Trường Khác';
const pageDescription = 'Bảng so sánh chi tiết Trường Việt Anh với các trường tiểu học song ngữ hàng đầu tại TP.HCM.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/tieu-hoc/so-sanh';

const uspItems = [
  { icon: '🌍', text: 'Chương trình song ngữ Anh-Việt chuẩn quốc tế' },
  { icon: '👨‍🏫', text: 'Giáo viên nước ngoài dạy tiếng Anh chuyên sâu' },
  { icon: '🏆', text: 'Học sinh đạt thành tích xuất sắc các kỳ thi' },
  { icon: '🎨', text: 'Phương pháp giảng dạy hiện đại, lấy học sinh làm trung tâm' },
  { icon: '🤝', text: 'Cộng đồng phụ huynh tích cực và gắn kết' },
  { icon: '⚽', text: 'Hơn 20 CLB ngoại khóa: thể thao, nghệ thuật, STEM' }
];

const metrics = [
  { number: '15+', label: 'Năm kinh nghiệm giáo dục' },
  { number: '500+', label: 'Học sinh Tiểu Học' },
  { number: '98%', label: 'Phụ huynh hài lòng' },
  { number: '3', label: 'Cơ sở tại TPHCM' }
];

const faqItems = [
  { question: 'Bảng so sánh có khách quan không?', answer: 'Bảng so sánh dựa trên dữ liệu thực tế và công khai. Ba/Mẹ có thể tự kiểm chứng từ các nguồn chính thức.' },
  { question: 'So sánh những trường nào?', answer: 'Bao gồm Trường Việt Anh và các trường song ngữ phổ biến tại TP.HCM trong cùng phân khúc học phí.' },
  { question: 'Ngoài bảng so sánh còn nhận được gì?', answer: 'Ba/Mẹ sẽ nhận thêm tư vấn cá nhân từ chuyên viên Tuyển sinh về trường phù hợp nhất.' }
];
---

<SqueezePageLayout
  title={pageTitle}
  description={pageDescription}
  keywords="so sánh trường tiểu học, Việt Anh, trường song ngữ, TPHCM"
  schoolLevel="tieu-hoc"
  funnelCode="so-sanh-tieu-hoc"
  canonicalUrl={canonicalUrl}
>
  <div slot="hero">
    <h1 class="hero-h1">So Sánh Trường Tiểu Học<br/>Việt Anh vs Các Trường Song Ngữ Khác</h1>
    <p class="hero-subtitle">Nhận bảng so sánh chi tiết 5 tiêu chí quan trọng nhất giữa các trường hàng đầu</p>
  </div>

  <div slot="usp">
    <USPGrid items={uspItems} />
  </div>

  <div slot="trust">
    <TrustMetrics metrics={metrics} />
  </div>

  <div slot="content">
    <div class="content-section">
      <h2>Bảng so sánh bao gồm gì?</h2>
      <div class="content-grid">
        <div class="content-card">
          <h3>Học phí & ưu đãi</h3>
          <p>So sánh mức học phí, các khoản phụ phí và chương trình ưu đãi của từng trường.</p>
        </div>
        <div class="content-card">
          <h3>Chương trình học</h3>
          <p>Đánh giá chất lượng chương trình, tỷ lệ tiếng Anh, và phương pháp giảng dạy.</p>
        </div>
        <div class="content-card">
          <h3>Cơ sở vật chất</h3>
          <p>So sánh khuôn viên, phòng học, thư viện, sân chơi và trang thiết bị.</p>
        </div>
        <div class="content-card">
          <h3>Kết quả đầu ra</h3>
          <p>Thành tích học sinh, tỷ lệ đỗ vào các trường THCS chất lượng cao.</p>
        </div>
      </div>
    </div>
  </div>

  <div slot="form">
    <h2 class="form-heading">Nhận bảng so sánh chi tiết</h2>
    <p class="form-subheading">Gửi qua email trong 2 phút – Hoàn toàn miễn phí</p>
    <LeadFormTwoStepEmailFirst
      formId="tuyen-sinh-form"
      funnelCode="so-sanh-tieu-hoc"
      schoolLevel="tieu-hoc"
      submitText="Nhận bảng so sánh"
      successMessage="Bảng so sánh đã gửi qua email! Kiểm tra hộp thư để xem chi tiết."
    />
  </div>

  <div slot="faq">
    <FAQSection items={faqItems} title="Câu hỏi về So sánh trường" />
  </div>
</SqueezePageLayout>

<style>
  .hero-h1 { font-family: "Montserrat", sans-serif; font-size: clamp(1.75rem, 5vw, 2.75rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
  .hero-subtitle { font-size: clamp(1rem, 3vw, 1.25rem); font-weight: 500; opacity: 0.95; }
  .content-section h2 { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 2rem; color: #1F4E79; text-align: center; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .content-card { padding: 2rem; background: white; border: 1px solid #e0e0e0; border-radius: 12px; transition: all 0.3s ease; }
  .content-card:hover { border-color: #E8792B; box-shadow: 0 8px 20px rgba(232, 121, 43, 0.12); transform: translateY(-4px); }
  .content-card h3 { font-family: "Montserrat", sans-serif; font-size: 1.25rem; font-weight: 700; color: #1F4E79; margin-bottom: 1rem; }
  .content-card p { font-size: 0.95rem; line-height: 1.6; color: #666666; }
  .form-heading { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: #1F4E79; margin-bottom: 0.5rem; }
  .form-subheading { font-size: 1rem; color: #666666; margin-bottom: 2rem; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .content-card { padding: 1.5rem; } }
</style>
