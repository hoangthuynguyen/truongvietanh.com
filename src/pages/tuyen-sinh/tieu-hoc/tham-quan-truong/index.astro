---
import SqueezePageLayout from '../../../../layouts/SqueezePageLayout.astro';
import LeadFormTwoStepEmailFirst from '../../../../components/LeadFormTwoStepEmailFirst.astro';
import USPGrid from '../../../../components/USPGrid.astro';
import TrustMetrics from '../../../../components/TrustMetrics.astro';
import FAQSection from '../../../../components/FAQSection.astro';

const pageTitle = 'Đặt Lịch Tham Quan Trường – Tiểu Học Việt Anh';
const pageDescription = 'Đặt lịch tham quan trường Việt Anh để trải nghiệm thực tế chương trình Tiểu Học song ngữ. Miễn phí, có xe đưa đón.';
const canonicalUrl = 'https://truongvietanh.com/tuyen-sinh/tieu-hoc/tham-quan-truong';

const uspItems = [
  { icon: '🌍', text: 'Chương trình song ngữ Anh-Việt chuẩn quốc tế' },
  { icon: '👨‍🏫', text: 'Giáo viên nước ngoài dạy tiếng Anh chuyên sâu' },
  { icon: '🏆', text: 'Học sinh đạt thành tích xuất sắc các kỳ thi' },
  { icon: '🎨', text: 'Phương pháp giảng dạy hiện đại, lấy học sinh làm trung tâm' },
  { icon: '🤝', text: 'Cộng đồng phụ huynh tích cực và gắn kết' },
  { icon: '⚽', text: 'Hơn 20 CLB ngoại khóa: thể thao, nghệ thuật, STEM' }
];

const metrics = [
  { number: '15+', label: 'Năm kinh nghiệm giáo dục' },
  { number: '500+', label: 'Học sinh Tiểu Học' },
  { number: '98%', label: 'Phụ huynh hài lòng' },
  { number: '3', label: 'Cơ sở tại TPHCM' }
];

const faqItems = [
  { question: 'Buổi tham quan kéo dài bao lâu?', answer: 'Khoảng 60-90 phút, bao gồm tham quan cơ sở vật chất, nghe giới thiệu chương trình và tư vấn cá nhân.' },
  { question: 'Có cần đặt lịch trước không?', answer: 'Có, Ba/Mẹ nên đặt lịch trước để nhà trường chuẩn bị tốt nhất. Mỗi buổi chỉ nhận tối đa 5 gia đình.' },
  { question: 'Bé có được đi cùng không?', answer: 'Rất khuyến khích! Bé sẽ được tham gia lớp học thử và trải nghiệm không gian học tập.' }
];
---

<SqueezePageLayout
  title={pageTitle}
  description={pageDescription}
  keywords="tham quan trường, school tour, tiểu học, trường Việt Anh"
  schoolLevel="tieu-hoc"
  funnelCode="school-tour-tieu-hoc"
  canonicalUrl={canonicalUrl}
>
  <div slot="hero">
    <h1 class="hero-h1">Đặt Lịch Tham Quan Trường<br/>Tiểu Học Trường Việt Anh</h1>
    <p class="hero-subtitle">Trải nghiệm thực tế cơ sở vật chất, gặp giáo viên và hiểu rõ chương trình song ngữ</p>
  </div>

  <div slot="usp">
    <USPGrid items={uspItems} />
  </div>

  <div slot="trust">
    <TrustMetrics metrics={metrics} />
  </div>

  <div slot="content">
    <div class="content-section">
      <h2>Tham quan trường – Bạn sẽ được gì?</h2>
      <div class="content-grid">
        <div class="content-card">
          <h3>Tham quan toàn diện</h3>
          <p>Thăm phòng học, thư viện, phòng STEM, sân thể thao, nhà ăn – tất cả cơ sở vật chất hiện đại.</p>
        </div>
        <div class="content-card">
          <h3>Gặp gỡ giáo viên</h3>
          <p>Trao đổi trực tiếp với giáo viên Việt Nam và nước ngoài về phương pháp giảng dạy.</p>
        </div>
        <div class="content-card">
          <h3>Bé thử lớp học</h3>
          <p>Con được tham gia một tiết học mẫu để trải nghiệm không khí lớp học thực tế.</p>
        </div>
        <div class="content-card">
          <h3>Tư vấn 1-1</h3>
          <p>Được tư vấn cá nhân về chương trình, học phí, và lộ trình phù hợp cho bé.</p>
        </div>
      </div>
    </div>
  </div>

  <div slot="form">
    <h2 class="form-heading">Đặt lịch tham quan miễn phí</h2>
    <p class="form-subheading">Chọn ngày phù hợp – Chúng tôi sẽ xác nhận trong 24h</p>
    <LeadFormTwoStepEmailFirst
      formId="tuyen-sinh-form"
      funnelCode="school-tour-tieu-hoc"
      schoolLevel="tieu-hoc"
      submitText="Đặt lịch ngay"
      successMessage="Đã nhận yêu cầu! Bộ phận Tuyển sinh sẽ liên hệ để xác nhận lịch tham quan."
    />
  </div>

  <div slot="faq">
    <FAQSection items={faqItems} title="Câu hỏi về Tham quan trường" />
  </div>
</SqueezePageLayout>

<style>
  .hero-h1 { font-family: "Montserrat", sans-serif; font-size: clamp(1.75rem, 5vw, 2.75rem); font-weight: 800; line-height: 1.2; margin-bottom: 1rem; }
  .hero-subtitle { font-size: clamp(1rem, 3vw, 1.25rem); font-weight: 500; opacity: 0.95; }
  .content-section h2 { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; margin-bottom: 2rem; color: #1F4E79; text-align: center; }
  .content-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto; }
  .content-card { padding: 2rem; background: white; border: 1px solid #e0e0e0; border-radius: 12px; transition: all 0.3s ease; }
  .content-card:hover { border-color: #E8792B; box-shadow: 0 8px 20px rgba(232, 121, 43, 0.12); transform: translateY(-4px); }
  .content-card h3 { font-family: "Montserrat", sans-serif; font-size: 1.25rem; font-weight: 700; color: #1F4E79; margin-bottom: 1rem; }
  .content-card p { font-size: 0.95rem; line-height: 1.6; color: #666666; }
  .form-heading { font-family: "Montserrat", sans-serif; font-size: clamp(1.5rem, 4vw, 2rem); font-weight: 700; color: #1F4E79; margin-bottom: 0.5rem; }
  .form-subheading { font-size: 1rem; color: #666666; margin-bottom: 2rem; }
  @media (max-width: 768px) { .content-grid { grid-template-columns: 1fr; } .content-card { padding: 1.5rem; } }
</style>
