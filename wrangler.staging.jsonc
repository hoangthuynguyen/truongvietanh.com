{
  "name": "truongvietanh-staging",
  "main": "./src/staging-worker.js",
  "compatibility_date": "2026-03-17",
  "workers_dev": true,
  "routes": [
    {
      "pattern": "staging.truongvietanh.com/*",
      "zone_name": "truongvietanh.com"
    }
  ],
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  }
}
